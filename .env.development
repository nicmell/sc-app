# Development-only: Vite dev server runs on :1420, but the Phase 0 WS
# bridge runs on :3000. Production `sc-app serve` mode serves the bundled
# frontend and the bridge from the same origin, so no env var is needed
# there — AppShell falls back to `window.location.origin`.
VITE_OSC_WS_URL=http://127.0.0.1:3000
