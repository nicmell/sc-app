{
  "port": 3000,
  "clock_chunk_size": 1024,
  "log_dir": "./logs",
  "routes": [
    {
      "pattern": "^/(dirt|clock|scope|bootstrap)(/|$)",
      "target": "127.0.0.1:57120"
    },
    {
      "pattern": "^/([sngbcdpu]_|notify|status|sync|cmd|dumpOSC|clearSched|error|quit|version)",
      "target": "127.0.0.1:57110"
    }
  ]
}
