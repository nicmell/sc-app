{
  "name": "sc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:wasm": "yarn build:wasm:scserver-commands",
    "build:wasm:scserver-commands": "cd crates/scserver-commands && cargo component build --release --features component --target wasm32-wasip1 && jco transpile target/wasm32-wasip1/release/scserver_commands.wasm -o pkg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sass": "^1.99.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
