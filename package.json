{
  "name": "sc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently --names vite,bridge --prefix-colors auto --kill-others-on-fail \"yarn dev\" \"yarn bridge\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "bridge": "cargo run --manifest-path src-tauri/Cargo.toml -- bridge",
    "osc": "./scripts/start-osc.sh",
    "scsynth-only": "./scripts/start-scsynth-only.sh",
    "superdirt-only": "./scripts/start-superdirt-only.sh",
    "superdirt-setup": "./scripts/setup-superdirt-deps.sh",
    "cleanup": "./scripts/cleanup.sh"
  },
  "dependencies": {
    "@sc-app/server-commands": "workspace:*",
    "@sc-app/synthdef-compiler": "workspace:*",
    "@sc-app/ui-foundation": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "osc-js": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
