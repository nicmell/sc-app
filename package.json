{
  "name": "sc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently --names vite,bridge --prefix-colors auto --kill-others-on-fail \"yarn dev\" \"yarn bridge\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "bridge": "cargo run --manifest-path src-tauri/Cargo.toml -- bridge",
    "osc": "./scripts/start-osc.sh",
    "scsynth-only": "./scripts/start-scsynth-only.sh",
    "superdirt-only": "./scripts/start-superdirt-only.sh",
    "strudeldirt-only": "./scripts/start-strudeldirt-only.sh",
    "superdirt-setup": "./scripts/setup-superdirt-deps.sh",
    "cleanup": "./scripts/cleanup.sh"
  },
  "dependencies": {
    "@sc-app/server-commands": "workspace:*",
    "@sc-app/synthdef-compiler": "workspace:*",
    "@sc-app/ui-foundation": "workspace:*",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/web": "^1.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "osc-js": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "yarn@4.14.1"
}
