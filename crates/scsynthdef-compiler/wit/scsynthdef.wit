    /// emphasizing only odd harmonics at an octave lower.
    buf-comb-l: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, %in: ugen-input, delay-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// buffer based comb delay line with no interpolation. See also [BufCombL]
    /// which uses linear interpolation, and BufCombC which uses cubic
    /// interpolation. Cubic interpolation is more computationally expensive
    /// than linear, but more accurate.
    /// 
    /// Args:
    /// - `buf`: buffer number
    /// - `%in`: the input signal
    /// - `delay-time`: delay time in seconds
    /// - `decay-time`: time for the echoes to decay by 60 decibels. If this
    /// time is negative then the feedback coefficient will be negative, thus
    /// emphasizing only odd harmonics at an octave lower.
    buf-comb-n: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, %in: ugen-input, delay-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// buffer based simple delay line with cubic interpolation
    /// 
    /// Args:
    /// - `buf`: buffer number
    /// - `%in`: the input signal
    /// - `delay-time`: delay time in seconds
    buf-delay-c: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, %in: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// buffer based simple delay line with linear interpolation
    /// 
    /// Args:
    /// - `buf`: buffer number
    /// - `%in`: the input signal
    /// - `delay-time`: delay time in seconds
    buf-delay-l: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, %in: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// buffer based simple delay line with no interpolation. See also BufDelayL
    /// which uses linear interpolation, and BufDelayC which uses cubic
    /// interpolation. Cubic interpolation is more computationally expensive
    /// than linear, but more accurate.
    /// 
    /// Args:
    /// - `buf`: buffer number
    /// - `%in`: the input signal
    /// - `delay-time`: delay time in seconds
    buf-delay-n: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, %in: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// returns the current duration of a buffer in seconds.
    /// 
    /// Args:
    /// - `buf`: a buffer
    buf-dur: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// returns the current number of allocated frames i.e. the size of the
    /// buffer. This is the equivalent of Clojure's count on a seq.
    /// 
    /// Args:
    /// - `buf`: a buffer
    buf-frames: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// returns a ratio by which the playback of a buffer is to be scaled
    /// 
    /// Args:
    /// - `buf`: a buffer
    buf-rate-scale: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// Read the contents of a buffer at a specified index
    /// 
    /// reads the contents of a buffer at a given index.
    /// 
    /// Args:
    /// - `num-channels`: The number of channels of the supplied buffer. This
    /// must be a fixed integer and not a signal or a control proxy. The
    /// architecture of the synth design cannot change after it is compiled.
    /// (Warning: if you supply a bufnum of a buffer that has a different number
    /// of channels than you have specified to buf-rd , it will fail silently).
    /// - `bufnum`: The index of the buffer to use
    /// - `phase`: Audio rate modulatable index into the buffer. Warning: The
    /// phase argument only offers precision for addressing 2**24 samples (about
    /// 6.3 minutes at 44100Hz)
    /// - `loop`: 1 means true, 0 means false. This is modulatable.
    /// - `interpolation`: 1 means no interpolation, 2 is linear, 4 is cubic
    /// interpolation
    buf-rd: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, bufnum: ugen-input, phase: ugen-input, loop: ugen-input, interpolation: ugen-input) -> ugen-input;

    /// returns the buffers current sample rate
    /// 
    /// Args:
    /// - `buf`: a buffer
    buf-sample-rate: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// current number of samples allocated in the buffer
    /// 
    /// Args:
    /// - `buf`: a buffer
    buf-samples: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// writes to a buffer at a given index. Note, buf-wr (in difference to
    /// buf-rd) does not do multichannel expansion, because input is an array.
    /// 
    /// Args:
    /// - `input-array`: input ugens (channelArray)
    /// - `bufnum`: the index of the buffer to use
    /// - `phase`: modulatable index into the buffer (has to be audio rate).
    /// - `loop`: 1 means true, 0 means false. This is modulatable
    buf-wr: func(def: borrow<synth-def>, ugen-rate: rate, input-array: list<ugen-input>, bufnum: ugen-input, phase: ugen-input, loop: ugen-input) -> ugen-input;

    /// Chorusing wavetable lookup oscillator. Produces sum of two signals at
    /// (freq +/- (beats / 2)). Due to summing, the peak amplitude is twice that
    /// of the wavetable.
    /// 
    /// Args:
    /// - `bufnum`: The number of a buffer filled in wavetable format
    /// - `freq`: Frequency in Hertz
    /// - `beats`: Beat frequency in Hertz
    c-osc: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, freq: ugen-input, beats: ugen-input) -> ugen-input;

    /// test for infinity, not-a-number, and denormals. If one of these is
    /// found, it posts a warning. Its output is as follows: 0 = a normal float,
    /// 1 = NaN, 2 = infinity, and 3 = a denormal.
    /// 
    /// Args:
    /// - `%in`: the UGen whose output is to be tested
    /// - `id`: an id number to identify this UGen.
    /// - `post`: One of three post modes: 0 = no posting; 1 = post a line for
    /// every bad value; 2 = post a line only when the floating-point
    /// classification changes (e.g., normal -> NaN and vice versa)
    check-bad-values: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, id: ugen-input, post: ugen-input) -> ugen-input;

    clear-buf: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input) -> ugen-input;

    /// Clip a signal outside given thresholds.
    /// 
    /// Clip a signal outside given thresholds. This differs from the ugen clip2
    /// in that it allows one to set both low and high thresholds.
    /// 
    /// Args:
    /// - `%in`: The signal to be clipped
    /// - `lo`: Low threshold of clipping. Must be less then hi
    /// - `hi`: High threshold of clipping. Must be greater then lo
    clip: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// Noise whose values are either -1 or 1.
    /// 
    /// This produces the maximum energy for the least peak to peak amplitude.
    /// Useful for generating percussive sounds such as snares and hand claps.
    /// Also useful for simulating wind or sea effects, for producing breath
    /// effects in wind instrument timbres or for producing the typical trance
    /// leads.
    clip-noise: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// When it receives a trigger, it tosses a coin, and either passes the
    /// trigger or doesn't.
    /// 
    /// Args:
    /// - `prob`: Value between 0 and 1 determines probability of either
    /// possibilities
    /// - `trig`: Trigger signal
    coin-gate: func(def: borrow<synth-def>, ugen-rate: rate, prob: ugen-input, trig: ugen-input) -> ugen-input;

    /// comb delay line, cubic interpolation
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    /// - `decay-time`: time for the echoes to decay by 60 decibels. If this
    /// time is negative then the feedback coefficient will be negative, thus
    /// emphasizing only odd harmonics at an octave lower.
    comb-c: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// comb delay line, linear interpolation
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    /// - `decay-time`: time for the echoes to decay by 60 decibels. If this
    /// time is negative then the feedback coefficient will be negative, thus
    /// emphasizing only odd harmonics at an octave lower.
    comb-l: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// comb delay line, no interpolation. See also CombL which uses linear
    /// interpolation, and CombC which uses cubic interpolation. Cubic
    /// interpolation is more computationally expensive than linear, but more
    /// accurate.
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    /// - `decay-time`: time for the echoes to decay by 60 decibels. If this
    /// time is negative then the feedback coefficient will be negative, thus
    /// emphasizing only odd harmonics at an octave lower.
    comb-n: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// General purpose hard-knee dynamic range processor.
    /// 
    /// The compander will modify the amplitude of the in signal based on an
    /// analysis of the control signal. Typically the in and control signals are
    /// the same. The amplitude of the control signal is calcuated using RMS
    /// (Root Mean Square) and the final amplitude of the in signal is
    /// calculated as a function of the amplitude threshold, and slopes either
    /// side (below and above) with some temporal modifications in terms of
    /// attack and release phases. It is a hard-knee processor which means that
    /// the response curve is a sharp angle rather than a rounded edge. If the
    /// control amplitude is less than the threshold, the slope below is used to
    /// calculate the amplitude modification. If this is steep (greater than 1)
    /// this will reduce the amplitude of quiet signals (the quieter the control
    /// amplitude the greater the reduction affect). Values < 1.0 are possible,
    /// but it means that a very low-level control signal will cause the input
    /// signal to be amplified, which would raise the noise floor. If the
    /// control amplitude is greater than the threshold, the slope above is used
    /// to calculate the amplitude modification. If this is steep (greater than
    /// 1) this will create expansion - loud signals will be made louder). Less
    /// than 1 will achieve compressions (louder signals are attenuated). The
    /// clamp and relax times modify when the amplitude modification takes place
    /// and ends. May be used to define: compressers, expanders, limiters, gates
    /// and duckers. For more information see:
    /// http://en.wikipedia.org/wiki/Audio_level_compression
    /// 
    /// Args:
    /// - `%in`: The signal to be compressed / expanded / gated
    /// - `control`: The signal whose amplitude determines the gain applied to
    /// the input signal. Often the same as in (for standard gating or
    /// compression) but should be different for ducking.
    /// - `thresh`: Control signal amplitude threshold, which determines the
    /// break point between slope-below and slope-above. Typically a value
    /// between 0 and 1.
    /// - `slope-below`: Slope of the amplitude curve below the threshold. A
    /// value of 1 means the output amplitude will match the control signal
    /// amplitude.
    /// - `slope-above`: Slope of the amplitude curve above the threshold. A
    /// value of 1 means the output amplitude will match the control signal
    /// amplitude.
    /// - `clamp-time`: Time taken for the amplitude adjustment to kick in fully
    /// (in seconds). This is usually pretty small, not much more than 10
    /// milliseconds (the default value). Also known as the time of the attack
    /// phase.
    /// - `relax-time`: The amount of time for the amplitude adjustment to be
    /// released. Usually a bit longer than clamp-time; if both times are too
    /// short, you can get some (possibly unwanted) artifacts. Also known as the
    /// time of the release phase.
    compander: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, control: ugen-input, thresh: ugen-input, slope-below: ugen-input, slope-above: ugen-input, clamp-time: ugen-input, relax-time: ugen-input) -> ugen-input;

    /// returns the current control rate block duration of the server in seconds
    control-dur: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the current control rate of the server
    control-rate: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// Strict convolution of two continuously changing inputs. Also see
    /// convolution2 for a cheaper CPU cost alternative for the case of a fixed
    /// kernel which can be changed with a trigger message. See Steven W Smith,
    /// The Scientist and Engineer's Guide to Digital Signal Processing: chapter
    /// 18: http:// www.dspguide.com/ch18.htm
    /// 
    /// Args:
    /// - `%in`: processing target
    /// - `kernel`: processing kernel.
    /// - `framesize`: size of FFT frame, must be a power of two
    convolution: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, kernel: ugen-input, framesize: ugen-input) -> ugen-input;

    /// Strict convolution with fixed kernel which can be updated using a
    /// trigger signal. See Steven W Smith, The Scientist and Engineer's Guide
    /// to Digital Signal Processing: chapter 18: http://
    /// www.dspguide.com/ch18.htm
    /// 
    /// Args:
    /// - `%in`: processing target
    /// - `kernel`: buffer index for the fixed kernel, may be modulated in
    /// combination with the trigger
    /// - `trigger`: update the kernel on a change from <= 0 to > 0
    /// - `framesize`: size of FFT frame, must be a power of two. Convolution
    /// uses twice this number internally, maximum value you can give this
    /// argument is 2^16 = 65536. Note that it gets progressively more expensive
    /// to run for higher powers! 512, 1024, 2048, 4096 standard.
    convolution2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, kernel: ugen-input, trigger: ugen-input, framesize: ugen-input) -> ugen-input;

    /// Strict convolution with fixed kernel which can be updated using a
    /// trigger signal. There is a linear crossfade between the buffers upon
    /// change. See Steven W Smith, The Scientist and Engineer's Guide to
    /// Digital Signal Processing: chapter 18: http://www.dspguide.com/ch18.htm
    /// 
    /// Args:
    /// - `%in`: processing target
    /// - `kernel`: buffer index for the fixed kernel, may be modulated in
    /// combination with the trigger
    /// - `trigger`: update the kernel on a change from <= 0 to > 0
    /// - `framesize`: size of FFT frame, must be a power of two. Convolution
    /// uses twice this number internally, maximum value you can give this
    /// argument is 2^16=65536. Note that it gets progressively more expensive
    /// to run for higher powers! 512, 1024, 2048, 4096 standard.
    /// - `crossfade`: The number of periods over which a crossfade is made. The
    /// default is 1. This must be an integer.
    convolution2-l: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, kernel: ugen-input, trigger: ugen-input, framesize: ugen-input, crossfade: ugen-input) -> ugen-input;

    /// Strict convolution with fixed kernel which can be updated using a
    /// trigger signal. The convolution is performed in the time domain, which
    /// is highly inefficient, and probably only useful for either very short
    /// kernel sizes, or for control rate signals.
    /// 
    /// Args:
    /// - `%in`: processing target
    /// - `kernel`: buffer index for the fixed kernel, may be modulated in
    /// combination with the trigger
    /// - `trigger`: update the kernel on a change from <= 0 to > 0
    /// - `framesize`: size of FFT frame, does not have to be a power of two.
    convolution3: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, kernel: ugen-input, trigger: ugen-input, framesize: ugen-input) -> ugen-input;

    /// Chaotic noise generator
    /// 
    /// A noise generator based on a chaotic function. Useful for generating
    /// percussive sounds such as snares and hand claps. Also useful for
    /// simulating wind or sea effects, for producing breath effects in wind
    /// instrument timbres or for producing the typical trance leads.
    /// 
    /// Args:
    /// - `chaos-param`: a parameter of the chaotic function with useful values
    /// from just below 1.0 to just above 2.0. Towards 2.0 the sound crackles.
    crackle: func(def: borrow<synth-def>, ugen-rate: rate, chaos-param: ugen-input) -> ugen-input;

    /// a linear-interpolating (cusp map chaotic) sound generator based on the
    /// difference equation: xn+1 = a - b*sqrt(|xn|)
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: first coefficient
    /// - `b`: 2nd coefficient
    /// - `xi`: initial value of x
    cusp-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, xi: ugen-input) -> ugen-input;

    /// a non-interpolating (cusp map chaotic) sound generator based on the
    /// difference equation: xn+1 = a - b*sqrt(|xn|)
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: first coefficient
    /// - `b`: 2nd coefficient
    /// - `xi`: initial value of x
    cusp-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, xi: ugen-input) -> ugen-input;

    /// outputs the initial value you give it.
    /// 
    /// Args:
    /// - `%in`: constant value to output, cannot be modulated, set at
    /// initialisation time
    dc: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dbrown cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity
    dbrown: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, lo: ugen-input, hi: ugen-input, step: ugen-input) -> ugen-input;

    /// Read values from a buffer on demand, using phase (index) value that is
    /// also pulled on demand. All inputs can be either demand ugen or any other
    /// ugen.
    /// 
    /// Args:
    /// - `bufnum`: buffer number to read from
    /// - `phase`: index into the buffer
    /// - `loop`: when phase exceeds number of frames in buffer, loops when set
    /// to 1
    dbufrd: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, phase: ugen-input, loop: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dbufwr cgen instead.
    dbufwr: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, phase: ugen-input, input: ugen-input, loop: ugen-input) -> ugen-input;

    /// triggered exponential decay.
    /// 
    /// This is essentially the same as integrator except that instead of
    /// supplying the coefficient directly, it is calculated from a 60 dB decay
    /// time. This is the time required for the integrator to lose 99.9 % of its
    /// value or -60dB. This is useful for exponential decaying envelopes
    /// triggered by impulses.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `decay-time`: 60 dB decay time in seconds
    decay: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// triggered exponential attack and exponential decay. Decay has a very
    /// sharp attack and can produce clicks. Decay2 rounds off the attack by
    /// subtracting one Decay from another. (decay in attack-time decay-time)
    /// equivalent to: (- (decay in attack-time decay-time) (decay in
    /// attack-time decay-time))
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `attack-time`: 60 dB attack time in seconds.
    /// - `decay-time`: 60 dB decay time in seconds.
    decay2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, attack-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// 2D Ambisonic B-format decoder. Decode a two dimensional ambisonic
    /// B-format signal to a set of speakers in a regular polygon. The outputs
    /// will be in clockwise order. The position of the first speaker is either
    /// center or left of center.
    /// 
    /// Args:
    /// - `num-channels`: number of output speakers. Typically 4 to 8.
    /// - `w`: B-format signal
    /// - `x`: B-format signal
    /// - `y`: B-format signal
    /// - `orientation`: Should be zero if the front is a vertex of the polygon.
    /// The first speaker will be directly in front. Should be 0.5 if the front
    /// bisects a side of the polygon. Then the first speaker will be the one
    /// left of center. Default is 0.5.
    decode-b2: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, w: ugen-input, x: ugen-input, y: ugen-input, orientation: ugen-input) -> ugen-input;

    /// the input signal value is truncated to an integer value and used as an
    /// index into an octave repeating table of note values (indices wrap around
    /// the table)
    /// 
    /// Args:
    /// - `bufnum`: Index of the buffer which contains the steps for each scale
    /// degree.
    /// - `%in`: The input signal.
    /// - `octave`: The number of steps per octave in the scale. The default is
    /// 12.
    degree-to-key: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input, octave: ugen-input) -> ugen-input;

    /// Tap a delay line from a del-tap-wr UGen
    /// 
    /// Args:
    /// - `buffer`: buffer where del-tap-wr has written signal. Max delay time
    /// is based on buffer size.
    /// - `phase`: the current phase of the del-tap-wr UGen. This is the output
    /// of DelTapWr.
    /// - `delay`: A delay time in seconds.
    /// - `interp`: the kind of interpolation to be used. 1 is none, 2 is
    /// linear, 4 is cubic.
    del-tap-rd: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, phase: ugen-input, delay: ugen-input, interp: ugen-input) -> ugen-input;

    /// Tap a delay line from a del-tap-wr UGen
    /// 
    /// Args:
    /// - `buffer`: the buffer to write signal into. Max delay time is based on
    /// buffer size.
    /// - `%in`: the signal to write to the buffer.
    del-tap-wr: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, %in: ugen-input) -> ugen-input;

    /// delay input signal by one frame of samples. Note: for audio-rate signals
    /// the delay is 1 audio frame, and for control-rate signals the delay is 1
    /// control period.
    /// 
    /// Args:
    /// - `%in`: input to be delayed.
    delay1: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// delay input signal by two frames of samples
    /// 
    /// Args:
    /// - `%in`: input to be delayed.
    delay2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// simple delay line, cubic interpolation.
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    delay-c: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// simple delay line, linear interpolation.
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    delay-l: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// simple delay line, no interpolation. See also DelayL which uses linear
    /// interpolation, and DelayC which uses cubic interpolation. Cubic
    /// interpolation is more computationally expensive than linear, but more
    /// accurate.
    /// 
    /// Args:
    /// - `%in`: the input signal
    /// - `max-delay-time`: the maximum delay time in seconds. Used to
    /// initialize the delay buffer size
    /// - `delay-time`: delay time in seconds
    delay-n: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, max-delay-time: ugen-input, delay-time: ugen-input) -> ugen-input;

    /// On every trigger it demands the next value from each of the demand ugens
    /// passed as args. Used to pull values from the other demand rate ugens. By
    /// design, a reset trigger only resets the demand ugens; it does not reset
    /// the value at Demand's output. Demand continues to hold its value until
    /// the next value is demanded, at which point its output value will be the
    /// first expected item in the list.
    /// 
    /// Args:
    /// - `trig`: Can be any signal. A trigger happens when the signal changes
    /// from non-positive to positive.
    /// - `reset`: Resets the list of ugens when triggered.
    /// - `demand-ugens`: list of demand rate ugens
    demand: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, reset: ugen-input, demand-ugens: ugen-input) -> ugen-input;

    /// Plays back break point envelope contours (levels, times, shapes) given
    /// by demand ugens. The next values are called when the next node is
    /// reached.
    /// 
    /// Args:
    /// - `level`: demand ugen (or other ugen) returning level values
    /// - `dur`: demand ugen (or other ugen) returning time values
    /// - `shape`: demand ugen (or other ugen) returning shape number - the
    /// number given is the shape number
    /// - `curve`: demand ugen (or other ugen) returning curve values - if shape
    /// is 5, this is the curve factor. The possible values are: 0 - flat
    /// segments, 1 - linear segments, the default, 2 - natural exponential
    /// growth and decay. In this case, the levels must all be nonzero and the
    /// have the same sign, 3 - sinusoidal S shaped segments, 4 - sinusoidal
    /// segments shaped like the sides of a Welch window, a Float - a curvature
    /// value for all segments, an Array of Floats - curvature values for each
    /// segments.
    /// - `gate`: control rate gate if gate is x >= 1, the ugen runs, if gate is
    /// 0 > x > 1, the ugen is released at the next level (doneAction), if gate
    /// is x <= 0, the ugen is sampled end held
    /// - `reset`: if reset crosses from nonpositive to positive, the ugen is
    /// reset at the next level. If it is > 1, it is reset immediately.
    /// - `level-scale`: demand ugen returning level scaling values
    /// - `level-bias`: demand ugen returning level offset values
    /// - `time-scale`: demand ugen returning time scaling values
    /// - `action`: Default: NO-ACTION
    demand-env-gen: func(def: borrow<synth-def>, ugen-rate: rate, level: ugen-input, dur: ugen-input, shape: ugen-input, curve: ugen-input, gate: ugen-input, reset: ugen-input, level-scale: ugen-input, level-bias: ugen-input, time-scale: ugen-input, action: ugen-input) -> ugen-input;

    /// search a buffer for a value
    detect-index: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input) -> ugen-input;

    /// If the signal input starts with silence at the beginning of the synth's
    /// duration, then DetectSilence will wait indefinitely until the first
    /// sound before starting to monitor for silence. This UGen outputs 1 if
    /// silence is detected, otherwise 0.
    /// 
    /// Args:
    /// - `%in`: any source
    /// - `amp`: when input falls below this, evaluate done action
    /// - `time`: the minimum duration of the input signal which input must fall
    /// below thresh before this triggers. The default is 0.1 seconds
    /// - `action`: the action to perform when silence is detected. Default:
    /// NO-ACTION
    detect-silence: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, amp: ugen-input, time: ugen-input, action: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dgeom cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity
    dgeom: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, start: ugen-input, grow: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dibrown cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity
    dibrown: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, lo: ugen-input, hi: ugen-input, step: ugen-input) -> ugen-input;

    /// stream audio in from disk file
    /// 
    /// Continuously play a longer soundfile from disk. This requires a buffer
    /// to be preloaded with one buffer size of sound. If loop is set to 1, the
    /// soundfile will loop.
    /// 
    /// Args:
    /// - `num-channels`: Number of channels in the incoming audio.
    /// - `bufnum`: id of buffer
    /// - `loop`: Soundfile will loop if 1 otherwise not.
    disk-in: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, bufnum: ugen-input, loop: ugen-input) -> ugen-input;

    /// stream audio out to disk file
    /// 
    /// The output of DiskOut is the number of frames written to disk. Note that
    /// the number of channels in the buffer and the channelsArray must be the
    /// same, otherwise DiskOut will fail silently (and not write anything to
    /// your file).
    /// 
    /// Args:
    /// - `bufnum`: the number of the buffer to write to (prepared with
    /// /b-write)
    /// - `channels-array`: the Array of channels to write to the file.
    disk-out: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the diwhite cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity
    diwhite: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    donce: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Outputs a one when the src ugen (typically an envelope) has finished
    /// 
    /// Args:
    /// - `src`: ugen to monitor
    done: func(def: borrow<synth-def>, ugen-rate: rate, src: ugen-input) -> ugen-input;

    /// Print the value of an input demand ugen. The print-out is in the form:
    /// label: value block offset: offset. WARNING: Printing values from the
    /// Server is intensive for the CPU. Poll should be used for debugging
    /// purposes.
    /// 
    /// Args:
    /// - `%in`: demand ugen to poll values from
    /// - `trig-id`: if greater than 0, a '/tr' message is sent back to the
    /// client (similar to send-trig)
    /// - `label`: a label string
    /// - `run`: activation switch 0 or 1 (can be a demand ugen)
    dpoll: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig-id: ugen-input, label: ugen-input, run: ugen-input) -> ugen-input;

    /// Demand rate random sequence generator. Generate a random ordering of an
    /// input sequence.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `num-repeats`: number of repeats
    drand: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, num-repeats: ugen-input) -> ugen-input;

    /// Demand rate sequence generator. Outputs a sequence of values, possibly
    /// repeating multiple times. Use INF as a repeat val to create an endless
    /// loop.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `num-repeats`: number of repeats
    dseq: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, num-repeats: ugen-input) -> ugen-input;

    /// Demand rate sequence generator. Generates a sequence of values like
    /// dseq, except outputs only count total values, rather than repeating.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `count`: number of values to return
    dser: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, count: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dseries cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity.
    dseries: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, start: ugen-input, step: ugen-input) -> ugen-input;

    /// Demand rate random sequence generator. Shuffle a sequence once and then
    /// output it one or more times.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `num-repeats`: number of repeats
    dshuf: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, num-repeats: ugen-input) -> ugen-input;

    /// Replicates input values n times on demand. Both inputs can be demand
    /// rate ugens.
    /// 
    /// Args:
    /// - `num-repeats`: number of repeats (can be a demand ugen)
    /// - `%in`: input ugen
    dstutter: func(def: borrow<synth-def>, ugen-rate: rate, num-repeats: ugen-input, %in: ugen-input) -> ugen-input;

    /// A demand rate switch. In difference to Dswitch1, Dswitch embeds all
    /// items of an input demand ugen first before looking up the next index.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `index`: which of the inputs to return
    dswitch: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, index: ugen-input) -> ugen-input;

    /// A demand rate switch that can be used to select one of multiple demand
    /// rate inputs.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `index`: which of the inputs to return
    dswitch1: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, index: ugen-input) -> ugen-input;

    /// Generates random impulses from 0 to +1.
    /// 
    /// Args:
    /// - `density`: average number of impulses per second
    dust: func(def: borrow<synth-def>, ugen-rate: rate, density: ugen-input) -> ugen-input;

    /// Generates random impulses from -1 to +1.
    /// 
    /// Args:
    /// - `density`: average number of impulses per second.
    dust2: func(def: borrow<synth-def>, ugen-rate: rate, density: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the duty cgen instead.
    /// 
    /// Args:
    /// - `action`: Default: NO-ACTION
    duty: func(def: borrow<synth-def>, ugen-rate: rate, dur: ugen-input, reset: ugen-input, action: ugen-input, level: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the dwhite cgen instead.
    /// 
    /// Args:
    /// - `length`: Default: positive infinity
    dwhite: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// Demand rate random sequence generator. Generate a random ordering of the
    /// given sequence without repeating any element until all elements have
    /// been returned.
    /// 
    /// Args:
    /// - `%list`: array of values or other ugens
    /// - `num-repeats`: number of repeats
    dxrand: func(def: borrow<synth-def>, ugen-rate: rate, %list: ugen-input, num-repeats: ugen-input) -> ugen-input;

    /// envelope generator, interpolates across a path of control points over
    /// time, see the overtone.sc.envelope functions to generate the control
    /// points array Note: The actual minimum duration of a segment is not zero,
    /// but one sample step for audio rate and one block for control rate. This
    /// may result in asynchronicity when in two envelopes of different number
    /// of levels, the envelope times add up to the same total duration.
    /// Similarly, when modulating times, the new time is only updated at the
    /// end of the current segment - this may lead to asynchronicity of two
    /// envelopes with modulated times.
    /// 
    /// Args:
    /// - `envelope`: an Array of Controls.
    /// - `gate`: this triggers the envelope and holds it open while > 0. If the
    /// envelope is fixed-length (e.g. perc), the gate argument is used as a
    /// simple trigger. If it is an sustaining envelope (e.g. adsr, asr), the
    /// envelope is held open until the gate becomes 0, at which point is
    /// released. If the gate of an env-gen is set to -1 or below, then the
    /// envelope will cutoff immediately. The time for it to cutoff is the
    /// amount less than -1, with -1 being as fast as possible, -1.5 being a
    /// cutoff in 0.5 seconds, etc. The cutoff shape is linear.
    /// - `level-scale`: scales the levels of the breakpoints.
    /// - `level-bias`: offsets the levels of the breakpoints.
    /// - `time-scale`: scales the durations of the segments.
    /// - `action`: an integer representing an action to be executed when the
    /// env is finished playing. This can be used to free the enclosing synth,
    /// etc.
    env-gen: func(def: borrow<synth-def>, ugen-rate: rate, envelope: ugen-input, gate: ugen-input, level-scale: ugen-input, level-bias: ugen-input, time-scale: ugen-input, action: ugen-input) -> ugen-input;

    /// Generates a single random float value in an exponential distributions
    /// from lo to hi.
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated float
    /// - `hi`: Maximum value of generated float
    exp-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// a cubic-interpolating feedback sine with chaotic phase indexing sound
    /// generator. This uses a linear congruential function to drive the phase
    /// indexing of a sine wave. For im = 1, fb = 0, and a = 1 a normal sinewave
    /// results.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `im`: index multiplier amount
    /// - `fb`: feedback amount
    /// - `a`: phase multiplier amount
    /// - `c`: phase increment amount
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    fb-sine-c: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, im: ugen-input, fb: ugen-input, a: ugen-input, c: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// a linear-interpolating feedback sine with chaotic phase indexing sound
    /// generator. This uses a linear congruential function to drive the phase
    /// indexing of a sine wave. For im = 1, fb = 0, and a = 1 a normal sinewave
    /// results.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `im`: index multiplier amount
    /// - `fb`: feedback amount
    /// - `a`: phase multiplier amount
    /// - `c`: phase increment amount
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    fb-sine-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, im: ugen-input, fb: ugen-input, a: ugen-input, c: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// a non-interpolating feedback sine with chaotic phase indexing sound
    /// generator. This uses a linear congruential function to drive the phase
    /// indexing of a sine wave. For im = 1, fb = 0, and a = 1 a normal sinewave
    /// results.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `im`: index multiplier amount
    /// - `fb`: feedback amount
    /// - `a`: phase multiplier amount
    /// - `c`: phase increment amount
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    fb-sine-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, im: ugen-input, fb: ugen-input, a: ugen-input, c: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// fast fourier transform, converts input data from the time to the
    /// frequency domain and stores the result in a buffer (audio waveform ->
    /// graph equalizer bands) Output is -1 except when an FFT frame is ready,
    /// when the output is the buffer index. This creates a special kind of
    /// slower pseudo-rate (built on top of control rate) which all the pv-ugens
    /// understand.
    /// 
    /// Args:
    /// - `buffer`: The buffer where a frame will be held. Its size must be a
    /// power of two. local-buf is useful here, because processes should not
    /// share data between synths. (Note: most PV UGens operate on this data in
    /// place. Use buffer-2n if you wish to create an external buffer.
    /// - `%in`: the signal to be analyzed. The signal's rate determines the
    /// rate at which the input is read.
    /// - `hop`: the amount of offset from one FFT analysis frame to the next,
    /// measured in multiples of the analysis frame size. This can range between
    /// zero and one, and the default is 0.5 (meaning each frame has a 50%
    /// overlap with the preceding/following frames).
    /// - `wintype`: defines how the data is windowed: RECT is for rectangular
    /// windowing, simple but typically not recommended; SINE (the default) is
    /// for Sine windowing, typically recommended for phase-vocoder work; HANN
    /// is for Hann windowing, typically recommended for analysis work.
    /// - `active`: is a simple control allowing FFT analysis to be active (>0)
    /// or inactive (<=0). This is mainly useful for signal analysis processes
    /// which are only intended to analyse at specific times rather than
    /// continuously
    /// - `winsize`: the windowed audio frames are usually the same size as the
    /// buffer. If you wish the FFT to be zero-padded then you can specify a
    /// window size smaller than the actual buffer size (e.g. window size 1024
    /// with buffer size 2048). Both values must still be a power of two. Leave
    /// this at its default of zero for no zero-padding.
    fft: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, %in: ugen-input, hop: ugen-input, wintype: ugen-input, active: ugen-input, winsize: ugen-input) -> ugen-input;

    /// Outputs the necessary signal for FFT chains, without doing an FFT on a
    /// signal
    /// 
    /// Args:
    /// - `buffer`: a buffer to condition for FFT use
    /// - `hop`: the hop size for timing triggers
    /// - `polar`: a flag. If 0.0, the buffer will be prepared for complex data,
    /// if > 0.0, polar data is set up.
    fft-trigger: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, hop: ugen-input, polar: ugen-input) -> ugen-input;

    /// first order filter section. Formula is equivalent to: out(i) = (a0 *
    /// in(i)) + (a1 * in(i-1)) + (b1 * out(i-1))
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `a0`: first coefficient
    /// - `a1`: second coefficient
    /// - `b1`: third coefficient
    fos: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, a0: ugen-input, a1: ugen-input, b1: ugen-input) -> ugen-input;

    /// Very fast sine wave generator (2 PowerPC instructions per output
    /// sample!) implemented using a ringing filter. This generates a much
    /// cleaner sine wave than a table lookup oscillator and is a lot faster.
    /// However, the amplitude of the wave will vary with frequency. Generally
    /// the amplitude will go down as you raise the frequency and go up as you
    /// lower the frequency. WARNING: In the current implementation, the
    /// amplitude can blow up if the frequency is modulated by certain
    /// alternating signals.
    /// 
    /// Args:
    /// - `freq`: frequency in Hertz
    /// - `iphase`: phase offset or modulator in radians
    f-sin-osc: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input) -> ugen-input;

    /// Fold a signal outside given thresholds.
    /// 
    /// Folds input wave to within the lo and hi thresholds. This differs from
    /// the ugen fold2 in that it allows one to set both low and high
    /// thresholds.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lo`: low threshold
    /// - `hi`: high threshold
    fold: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// Generates a set of harmonics around a formant frequency at a given
    /// fundamental frequency. The frequency inputs are read at control rate
    /// only, so if you use an audio rate UGen as an input, it will only be
    /// sampled at the start of each audio synthesis block.
    /// 
    /// Args:
    /// - `fundfreq`: Fundamental frequency in Hertz (control rate)
    /// - `formfreq`: Formant frequency in Hertz (control rate)
    /// - `bwfreq`: Pulse width frequency in Hertz. Controls the bandwidth of
    /// the formant (control rate)
    formant: func(def: borrow<synth-def>, ugen-rate: rate, fundfreq: ugen-input, formfreq: ugen-input, bwfreq: ugen-input) -> ugen-input;

    /// a resonant filter whose impulse response is like that of a sine wave
    /// with a Decay2 envelope over it. The great advantage to this filter over
    /// FOF is that there is no limit to the number of overlapping grains since
    /// the grain is just the impulse response of the filter. Note that if
    /// attacktime == decaytime then the signal cancels out and if attacktime >
    /// decaytime then the impulse response is inverted.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: resonant frequency in Hertz
    /// - `attack-time`: 60 dB attack time in seconds
    /// - `decay-time`: 60 dB decay time in seconds
    formlet: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, attack-time: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// Free the specified node when triggered
    /// 
    /// Args:
    /// - `trig`: when triggered, frees node
    /// - `id`: node to be freed
    free: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, id: ugen-input) -> ugen-input;

    /// Free the enclosing synth when triggered
    /// 
    /// Args:
    /// - `%in`: input signal
    free-self: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Free the enclosing synth when the src ugen finishes (e.g. env-gen,
    /// play-buf, linen...)
    /// 
    /// Args:
    /// - `src`: the ugen to check for done
    free-self-when-done: func(def: borrow<synth-def>, ugen-rate: rate, src: ugen-input) -> ugen-input;

    /// A reverb coded from experiments with faust. Valid parameter range from 0
    /// to 1. Values outside this range are clipped by the UGen.
    /// 
    /// Args:
    /// - `%in`: The input signal
    /// - `mix`: Dry/wet balance. range 0..1
    /// - `room`: Room size. rage 0..1
    /// - `damp`: Reverb HF damp. range 0..1
    free-verb: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, mix: ugen-input, room: ugen-input, damp: ugen-input) -> ugen-input;

    /// A two-channel reverb coded from experiments with faust. Valid parameter
    /// range from 0 to 1. Values outside this range are clipped by the UGen.
    /// 
    /// Args:
    /// - `%in`: Input signal channel 1
    /// - `in2`: Input signal channel 2
    /// - `mix`: Dry/wet balance. range 0..1
    /// - `room`: Room size. rage 0..1
    /// - `damp`: Reverb HF damp. range 0..1
    free-verb2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, in2: ugen-input, mix: ugen-input, room: ugen-input, damp: ugen-input) -> ugen-input;

    /// FreqShift implements single sideband amplitude modulation, also known as
    /// frequency shifting, but not to be confused with pitch shifting.
    /// Frequency shifting moves all the components of a signal by a fixed
    /// amount but does not preserve the original harmonic relationships.
    /// 
    /// Args:
    /// - `%in`: The signal to process
    /// - `freq`: Amount of shift in cycles per second
    /// - `phase`: Phase of the frequency shift (0 - 2pi)
    freq-shift: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, phase: ugen-input) -> ugen-input;

    /// A two-channel reverb UGen, based on the \"GVerb\" LADSPA effect by
    /// Juhana Sadeharju (kouhia at nic.funet.fi). WARNING - in the current
    /// version of the server, there are severe noise issues when you attempt to
    /// modify the roomsize or set it to a value greater than 40.
    /// 
    /// Args:
    /// - `%in`: mono input
    /// - `roomsize`: in squared meters.
    /// - `revtime`: in seconds
    /// - `damping`: 0 to 1, high frequency rolloff, 0 damps the reverb signal
    /// completely, 1 not at all
    /// - `inputbw`: 0 to 1, same as damping control, but on the input signal
    /// - `spread`: a control on the stereo spread and diffusion of the reverb
    /// signal
    /// - `drylevel`: amount of dry signal
    /// - `earlyreflevel`: amount of early reflection level
    /// - `taillevel`: amount of tail level
    /// - `maxroomsize`: to set the size of the delay lines.
    g-verb: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, roomsize: ugen-input, revtime: ugen-input, damping: ugen-input, inputbw: ugen-input, spread: ugen-input, drylevel: ugen-input, earlyreflevel: ugen-input, taillevel: ugen-input, maxroomsize: ugen-input) -> ugen-input;

    /// Gate or hold
    /// 
    /// Lets signal flow when trig is positive, otherwise holds last input value
    /// 
    /// Args:
    /// - `%in`: Input signal.
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    gate: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig: ugen-input) -> ugen-input;

    /// A linear-interpolating (gingerbreadman map chaotic) sound generator
    /// based on the difference equations: xn+1 = 1 - yn + |xn| yn+1 = xn
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hz
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    gbman-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// A non-interpolating (gingerbreadman map chaotic) sound generator based
    /// on the difference equations: xn+1 = 1 - yn + |xn| yn+1 = xn
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hz
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    gbman-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// An implementation of the dynamic stochastic synthesis generator
    /// conceived by Iannis Xenakis and described in Formalized Music (1992,
    /// Stuyvesant, NY: Pendragon Press) chapter 9 (pp 246-254) and chapters 13
    /// and 14 (pp 289-322). The BASIC program in the book was written by
    /// Marie-Helene Serra so I think it helpful to credit her too. The program
    /// code has been adapted to avoid infinities in the probability
    /// distribution functions. The distributions are hard-coded in C but there
    /// is an option to have new amplitude or time breakpoints sampled from a
    /// continuous controller input.
    /// 
    /// Args:
    /// - `ampdist`: Choice of probability distribution for the next
    /// perturbation of the amplitude of a control point. The distributions are
    /// (adapted from the GENDYN program in Formalized Music): 0- LINEAR,1-
    /// CAUCHY, 2- LOGIST, 3- HYPERBCOS, 4- ARCSINE, 5- EXPON, 6- SINUS, Where
    /// the sinus (Xenakis' name) is in this implementation taken as sampling
    /// from a third party oscillator. See example below.
    /// - `durdist`: Choice of distribution for the perturbation of the current
    /// inter control point duration.
    /// - `adparam`: A parameter for the shape of the amplitude probability
    /// distribution, requires values in the range 0.0001 to 1 (there are safety
    /// checks in the code so don't worry too much if you want to modulate!)
    /// - `ddparam`: A parameter for the shape of the duration probability
    /// distribution, requires values in the range 0.0001 to 1
    /// - `minfreq`: Minimum allowed frequency of oscillation for the Gendy1
    /// oscillator, so gives the largest period the duration is allowed to take
    /// on.
    /// - `maxfreq`: Maximum allowed frequency of oscillation for the Gendy1
    /// oscillator, so gives the smallest period the duration is allowed to take
    /// on.
    /// - `ampscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for amplitude. An ampscale of 1.0 allows the full range of
    /// -1 to 1 for a change of amplitude.
    /// - `durscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for duration. An ampscale of 1.0 allows the full range of -1
    /// to 1 for a change of duration.
    /// - `init-cps`: Initialise the number of control points in the memory.
    /// Xenakis specifies 12. There would be this number of control points per
    /// cycle of the oscillator, though the oscillator's period will constantly
    /// change due to the duration distribution.
    /// - `knum`: Current number of utilised control points, allows modulation.
    gendy1: func(def: borrow<synth-def>, ugen-rate: rate, ampdist: ugen-input, durdist: ugen-input, adparam: ugen-input, ddparam: ugen-input, minfreq: ugen-input, maxfreq: ugen-input, ampscale: ugen-input, durscale: ugen-input, init-cps: ugen-input, knum: ugen-input) -> ugen-input;

    /// See gendy1 help file for background. This variant of GENDYN is closer to
    /// that presented in Hoffmann, Peter. (2000) The New GENDYN Program.
    /// Computer Music Journal 24:2, pp 31-38.
    /// 
    /// Args:
    /// - `ampdist`: Choice of probability distribution for the next
    /// perturbation of the amplitude of a control point. The distributions are
    /// (adapted from the GENDYN program in Formalized Music): 0- LINEAR, 1-
    /// CAUCHY, 2- LOGIST, 3- HYPERBCOS, 4- ARCSINE, 5- EXPON, 6- SINUS, Where
    /// the sinus (Xenakis' name) is in this implementation taken as sampling
    /// from a third party oscillator.
    /// - `durdist`: Choice of distribution for the perturbation of the current
    /// inter control point duration.
    /// - `adparam`: A parameter for the shape of the amplitude probability
    /// distribution, requires values in the range 0.0001 to 1 (there are safety
    /// checks in the code so don't worry too much if you want to modulate!)
    /// - `ddparam`: A parameter for the shape of the duration probability
    /// distribution, requires values in the range 0.0001 to 1
    /// - `minfreq`: Minimum allowed frequency of oscillation for the Gendy1
    /// oscillator, so gives the largest period the duration is allowed to take
    /// on.
    /// - `maxfreq`: Maximum allowed frequency of oscillation for the Gendy1
    /// oscillator, so gives the smallest period the duration is allowed to take
    /// on.
    /// - `ampscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for amplitude. An ampscale of 1.0 allows the full range of
    /// -1 to 1 for a change of amplitude.
    /// - `durscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for duration. An ampscale of 1.0 allows the full range of -1
    /// to 1 for a change of duration.
    /// - `init-cps`: Initialise the number of control points in the memory.
    /// Xenakis specifies 12. There would be this number of control points per
    /// cycle of the oscillator, though the oscillator's period will constantly
    /// change due to the duration distribution.
    /// - `knum`: Current number of utilised control points, allows modulation.
    /// - `a`: parameter for Lehmer random number generator perturbed by Xenakis
    /// as in ((old*a)+c)%1.0
    /// - `c`: parameter for Lehmer random number generator perturbed by Xenakis
    gendy2: func(def: borrow<synth-def>, ugen-rate: rate, ampdist: ugen-input, durdist: ugen-input, adparam: ugen-input, ddparam: ugen-input, minfreq: ugen-input, maxfreq: ugen-input, ampscale: ugen-input, durscale: ugen-input, init-cps: ugen-input, knum: ugen-input, a: ugen-input, c: ugen-input) -> ugen-input;

    /// See Gendy1 help file for background. This variant of GENDYN normalises
    /// the durations in each period to force oscillation at the desired pitch.
    /// The breakpoints still get perturbed as in Gendy1. There is some
    /// glitching in the oscillator caused by the stochastic effects: control
    /// points as they vary cause big local jumps of amplitude. Put ampscale and
    /// durscale low to minimise this. All parameters can be modulated at
    /// control rate except for initCPs which is used only at initialisation.
    /// 
    /// Args:
    /// - `ampdist`: Choice of probability distribution for the next
    /// perturbation of the amplitude of a control point. The distributions are
    /// (adapted from the GENDYN program in Formalized Music): 0- LINEAR,1-
    /// CAUCHY, 2- LOGIST, 3- HYPERBCOS, 4- ARCSINE, 5- EXPON, 6- SINUS, Where
    /// the sinus (Xenakis' name) is in this implementation taken as sampling
    /// from a third party oscillator.
    /// - `durdist`: Choice of distribution for the perturbation of the current
    /// inter control point duration.
    /// - `adparam`: A parameter for the shape of the amplitude probability
    /// distribution, requires values in the range 0.0001 to 1 (there are safety
    /// checks in the code so don't worry too much if you want to modulate!)
    /// - `ddparam`: A parameter for the shape of the duration probability
    /// distribution, requires values in the range 0.0001 to 1
    /// - `freq`: Oscillation frquency.
    /// - `ampscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for amplitude. An ampscale of 1.0 allows the full range of
    /// -1 to 1 for a change of amplitude.
    /// - `durscale`: Normally 0.0 to 1.0, multiplier for the distribution's
    /// delta value for duration. An ampscale of 1.0 allows the full range of -1
    /// to 1 for a change of duration.
    /// - `init-cps`: Initialise the number of control points in the memory.
    /// Xenakis specifies 12. There would be this number of control points per
    /// cycle of the oscillator, though the oscillator's period will constantly
    /// change due to the duration distribution.
    /// - `knum`: Current number of utilised control points, allows modulation.
    gendy3: func(def: borrow<synth-def>, ugen-rate: rate, ampdist: ugen-input, durdist: ugen-input, adparam: ugen-input, ddparam: ugen-input, freq: ugen-input, ampscale: ugen-input, durscale: ugen-input, init-cps: ugen-input, knum: ugen-input) -> ugen-input;

    /// Granular synthesis with sound stored in a buffer
    /// 
    /// Args:
    /// - `num-channels`: the number of channels to output. If 1, mono is
    /// returned and pan is ignored.
    /// - `trigger`: a kr or ar trigger to start a new grain. If ar, grains
    /// after the start of the synth are sample accurate.
    /// - `dur`: size of the grain (in seconds).
    /// - `sndbuf`: the buffer holding a mono audio signal. If using
    /// multi-channel files, use Buffer.readChannel.
    /// - `rate`: the playback rate of the sampled sound
    /// - `pos`: the playback position for the grain to start with (0 is
    /// beginning, 1 is end of file)
    /// - `interp`: the interpolation method used for pitchshifting grains: 1 =
    /// no interpolation 2 = linear 4 = cubic interpolation (more
    /// computationally intensive)
    /// - `pan`: Determines where to pan the output. If num-channels = 1, no
    /// panning is done; if num-channels = 2, panning is similar to Pan2; if
    /// num-channels > 2, pannins is the same as PanAz.
    /// - `envbufnum`: the buffer number containing a singal to use for the
    /// grain envelope. -1 uses a built-in Hanning envelope.
    /// - `max-grains`: the maximum number of overlapping grains that can be
    /// used at a given time. This value is set at the UGens init time and can't
    /// be modified. This can be set lower for more efficient use of memory.
    grain-buf: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, trigger: ugen-input, dur: ugen-input, sndbuf: ugen-input, rate: ugen-input, pos: ugen-input, interp: ugen-input, pan: ugen-input, envbufnum: ugen-input, max-grains: ugen-input) -> ugen-input;

    /// Granular synthesis with frequency modulated sine tones
    /// 
    /// Args:
    /// - `num-channels`: the number of channels to output. If 1, mono is
    /// returned and pan is ignored.
    /// - `trigger`: a kr or ar trigger to start a new grain. If ar, grains
    /// after the start of the synth are sample accurate.
    /// - `dur`: size of the grain.
    /// - `car-freq`: the frequency of the FM grain's carrier oscillator
    /// - `mod-freq`: the frequency of the FM grain's modulating oscillator
    /// - `index`: the FM index
    /// - `pan`: Determines where to pan the output. If num-channels = 1, no
    /// panning is done; if num-channels = 2, panning is similar to Pan2; if
    /// numChannels > 2, pannins is the same as PanAz.
    /// - `envbufnum`: the buffer number containing a singal to use for the
    /// grain envelope. -1 uses a built-in Hanning envelope.
    /// - `max-grains`: the maximum number of overlapping grains that can be
    /// used at a given time. This value is set at the UGens init time and can't
    /// be modified. This can be set lower for more efficient use of memory.
    grain-fm: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, trigger: ugen-input, dur: ugen-input, car-freq: ugen-input, mod-freq: ugen-input, index: ugen-input, pan: ugen-input, envbufnum: ugen-input, max-grains: ugen-input) -> ugen-input;

    /// Granulate an input signal
    /// 
    /// Args:
    /// - `num-channels`: the number of channels to output. If 1, mono is
    /// returned and pan is ignored.
    /// - `trigger`: a kr or ar trigger to start a new grain. If ar, grains
    /// after the start of the synth are sample accurate.
    /// - `dur`: size of the grain.
    /// - `%in`: the input to granulate
    /// - `pan`: Determines where to pan the output. If num-channels = 1, no
    /// panning is done; if num-channels = 2, panning is similar to Pan2; if
    /// num-channels > 2, pannins is the same as PanAz.
    /// - `envbufnum`: the buffer number containing a singal to use for the
    /// grain envelope. -1 uses a built-in Hanning envelope.
    /// - `max-grains`: the maximum number of overlapping grains that can be
    /// used at a given time. This value is set at the UGens init time and can't
    /// be modified. This can be set lower for more efficient use of memory.
    grain-in: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, trigger: ugen-input, dur: ugen-input, %in: ugen-input, pan: ugen-input, envbufnum: ugen-input, max-grains: ugen-input) -> ugen-input;

    /// Granular synthesis with sine tones
    /// 
    /// Args:
    /// - `num-channels`: the number of channels to output. If 1, mono is
    /// returned and pan is ignored.
    /// - `trigger`: a kr or ar trigger to start a new grain. If ar, grains
    /// after the start of the synth are sample accurate.
    /// - `dur`: size of the grain.
    /// - `freq`: the frequency of the grain's oscillator
    /// - `pan`: Determines where to pan the output. If num-channels = 1, no
    /// panning is done; if num-channels = 2, panning is similar to Pan2; if
    /// numChannels > 2, pannins is the same as PanAz.
    /// - `envbufnum`: the buffer number containing a singal to use for the
    /// grain envelope. -1 uses a built-in Hanning envelope.
    /// - `max-grains`: the maximum number of overlapping grains that can be
    /// used at a given time. This value is set at the UGens init time and can't
    /// be modified. This can be set lower for more efficient use of memory.
    grain-sin: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, trigger: ugen-input, dur: ugen-input, freq: ugen-input, pan: ugen-input, envbufnum: ugen-input, max-grains: ugen-input) -> ugen-input;

    /// Random impulses from -1 to +1 given a density
    /// 
    /// Creates a sequence of random impulses from -1 to +1. Generates noise
    /// which results from flipping random bits in a word. This type of noise
    /// has a high RMS level relative to its peak to peak level. The spectrum is
    /// emphasized towards lower frequencies. Useful for generating percussive
    /// sounds such as snares and hand claps. Also useful for simulating wind or
    /// sea effects, for producing breath effects in wind instrument timbres or
    /// for producing the typical trance leads.
    gray-noise: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// second order high pass filter
    /// 
    /// A high pass filter lets through the frequencies above the cutoff point
    /// and successfully dampens the frequencies below the cutoff point. This
    /// effectively removes the fundamental frequency of the sound, leaving only
    /// the fizz harmonic overtones. High pass filters are rarely used in the
    /// creation of instruments and are predominantly used to create
    /// effervexcent sound effects of bright timbres that can be laid over the
    /// top of another low pass sound to increase the harmonic content.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: cutoff frequency
    hpf: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input) -> ugen-input;

    /// two point difference filter. Implements the formula: out(i) = 0.5 *
    /// (in(i) - in(i-1))
    hpz1: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// two zero fixed highpass. Implements the formula: out(i) = 0.25 * (in(i)
    /// - (2*in(i-1)) + in(i-2))
    hpz2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Returns a unique output value from zero to one for each input value
    /// according to a hash function. The same input value will always produce
    /// the same output value. The input need not be from zero to one.
    /// 
    /// Args:
    /// - `%in`: input signal
    hasher: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// a cubic-interpolating (henon map chaotic) sound generator based on the
    /// difference equation: x[n+2] = 1 - a*(x[n+1]^)2 + bx[n]. This equation
    /// was discovered by French astronomer Michel Hénon while studying the
    /// orbits of stars in globular clusters.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `x0`: initial value of x
    /// - `x1`: second value of x
    henon-c: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, x0: ugen-input, x1: ugen-input) -> ugen-input;

    /// a linear-interpolating (henon map chaotic) sound generator based on the
    /// difference equation: x[n+2] = 1 - a*(x[n+1]^)2 + bx[n]. This equation
    /// was discovered by French astronomer Michel Hénon while studying the
    /// orbits of stars in globular clusters.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `x0`: initial value of x
    /// - `x1`: second value of x
    henon-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, x0: ugen-input, x1: ugen-input) -> ugen-input;

    /// a non-interpolating (henon map chaotic) sound generator based on the
    /// difference equation: x[n+2] = 1 - a*(x[n+1]^)2 + bx[n]. This equation
    /// was discovered by French astronomer Michel Hénon while studying the
    /// orbits of stars in globular clusters.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `x0`: initial value of x
    /// - `x1`: second value of x
    henon-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, x0: ugen-input, x1: ugen-input) -> ugen-input;

    hilbert: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Args:
    /// - `ienvelope`: an InterplEnv (this is static for the life of the UGen)
    /// - `index`: a point to access within the InterplEnv
    i-env-gen: func(def: borrow<synth-def>, ugen-rate: rate, ienvelope: ugen-input, index: ugen-input) -> ugen-input;

    /// inverse fast fourier transform, converts buffer data from frequency
    /// domain to time domain The IFFT UGen converts the FFT data in-place (in
    /// the original FFT buffer) and overlap-adds the result to produce a
    /// continuous signal at its output.
    /// 
    /// Args:
    /// - `chain`: The FFT chain signal coming originally from an FFT UGen,
    /// perhaps via other PV UGens.
    /// - `wintype`: defines how the data is windowed: RECT is for rectangular
    /// windowing, simple but typically not recommended; SINE (the default) is
    /// for Sine windowing, typically recommended for phase-vocoder work; HANN
    /// is for Hann windowing, typically recommended for analysis work.
    /// - `winsize`: can be used to account for zero-padding, in the same way as
    /// the FFT UGen.
    ifft: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, wintype: ugen-input, winsize: ugen-input) -> ugen-input;

    /// Generates a single random integer value in uniform distribution from lo
    /// to hi
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated integer
    /// - `hi`: Maximum value of generated integer
    i-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// non band limited impulse oscillator. Outputs a single 1 every freq
    /// cycles per second and 0 the rest of the time.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `phase`: Phase offset in cycles ( 0..1 )
    impulse: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, phase: ugen-input) -> ugen-input;

    /// Read a signal from a bus.
    /// 
    /// in:kr is functionally similar to in-feedback. That is it reads all data
    /// on the bus whether it is from the current cycle or not. This allows for
    /// it to receive data from later in the node order. in:ar reads only data
    /// from the current cycle, and will zero data from earlier cycles (for use
    /// within that synth; the data remains on the bus). Because of this and the
    /// fact that the various out ugens mix their output with data from the
    /// current cycle but overwrite data from an earlier cycle it may be
    /// necessary to use a private control bus when this type of feedback is
    /// desired.
    /// 
    /// Args:
    /// - `bus`: the index of the bus to read in from
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. The default is 1. You cannot modulate this number by assigning it to
    /// an argument in a SynthDef.
    %in: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, num-channels: u32) -> ugen-input;

    /// read signal from a bus with a current or one cycle old timestamp
    /// 
    /// When the various output ugens (out, offsetOut, x-out) write data to a
    /// bus, they mix it with any data from the current cycle, but overwrite any
    /// data from the previous cycle. (replace-out overwrites all data
    /// regardless.) Thus depending on node order and what synths are writing to
    /// thep bus, the data on a given bus may be from the current cycle or be
    /// one cycle old at the time of reading. in:ar checks the timestamp of any
    /// data it reads in and zeros any data from the previous cycle (for use
    /// within that node; the data remains on the bus). This is fine for audio
    /// data, as it avoids feedback, but for control data it is useful to be
    /// able to read data from any place in the node order. For this reason
    /// in:kr also reads data that is older than the current cycle. In some
    /// cases we might also want to read audio from a node later in the current
    /// node order. This is the purpose of InFeedback. The delay introduced by
    /// this is one block size, which equals about 0.0014 sec at the default
    /// block size and sample rate. (See the resonator example below to see the
    /// implications of this.) The variably mixing and overwriting behaviour of
    /// the output ugens can make order of execution crucial. (No pun intended.)
    /// For example with a node order like the following the InFeedback ugen in
    /// Synth 2 will only receive data from Synth 1 (-> = write out; <- = read
    /// in): Synth 1 -> busA This synth overwrites the output of Synth3 before
    /// it reaches Synth 2 Synth 2 (with InFeedback) <- busA Synth 3 -> busA If
    /// Synth 1 were moved after Synth 2 then Synth 2's InFeedback would receive
    /// a mix of the output from Synth 1 and Synth 3. This would also be true if
    /// Synth 2 came after Synth1 and Synth 3. In both cases data from Synth 1
    /// and Synth 3 would have the same time stamp (either current or from the
    /// previous cycle), so nothing would be overwritten. Because of this it is
    /// often useful to allocate a separate bus for feedback. With the following
    /// arrangement Synth 2 will receive data from Synth3 regardless of Synth
    /// 1's position in the node order. Synth 1 -> busA Synth 2 (with
    /// InFeedback) <- busB Synth 3 -> busB + busA
    /// 
    /// Args:
    /// - `bus`: the index of the bus to read in from.
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. The default is 1. You cannot modulate this number by assigning it to
    /// an argument in a SynthDef.
    in-feedback: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, num-channels: u32) -> ugen-input;

    /// Tests if a signal is within a given range
    /// 
    /// If in is >= lo and <= hi output 1.0, otherwise output 0.0. Output is
    /// initially zero.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lo`: low threshold
    /// - `hi`: high threshold
    in-range: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// Test if a point is within a given rectangle.
    /// 
    /// Outputs one if the 2d coordinate of x,y input values falls inside a
    /// rectangle, else zero
    /// 
    /// Args:
    /// - `x`: X component signal
    /// - `y`: Y component signal
    in-rect: func(def: borrow<synth-def>, ugen-rate: rate, x: ugen-input, y: ugen-input, left: ugen-input, top: ugen-input, right: ugen-input, bottom: ugen-input) -> ugen-input;

    /// generates a trigger any time the bus is set
    /// 
    /// Any time the bus is 'touched' ie. has its value set (using \"/c_set\"
    /// etc.), a single impulse trigger will be generated. Its amplitude is the
    /// value that the bus was set to.
    /// 
    /// Args:
    /// - `bus`: the index of the bus to read in from.
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. The default is 1. You cannot modulate this number by assigning it to
    /// an argument in a SynthDef.
    in-trig: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, num-channels: u32) -> ugen-input;

    /// the input signal value is truncated to an integer and used as an index
    /// into the table
    index: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input) -> ugen-input;

    /// finds the (lowest) point in the buffer at which the input signal lies
    /// in-between the two values, and returns the index
    index-in-between: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input) -> ugen-input;

    /// leaky integrator. Integrates an input signal with a leak. The formula
    /// implemented is: out(0) = in(0) + (coef * out(-1))
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `coef`: leak coefficient
    integrator: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, coef: ugen-input) -> ugen-input;

    /// control rate to audio rate converter via linear interpolation.
    /// 
    /// Args:
    /// - `%in`: input signal
    k2-a: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Toggles between two values when a key on the keyboard is up or down.
    /// Note that this ugen does not prevent normal typing.
    /// 
    /// Args:
    /// - `keycode`: The keycode value of the key to check.
    /// - `minval`: The value to output when the key is not pressed.
    /// - `maxval`: The value to output when the key is pressed.
    /// - `lag`: lag factor
    key-state: func(def: borrow<synth-def>, ugen-rate: rate, keycode: ugen-input, minval: ugen-input, maxval: ugen-input, lag: ugen-input) -> ugen-input;

    /// A (12TET major/minor) key tracker based on a pitch class profile of
    /// energy across FFT bins and matching this to templates for major and
    /// minor scales in all transpositions. It assumes a 440 Hz concert A
    /// reference. Output is 0-11 C major to B major, 12-23 C minor to B minor
    /// 
    /// Args:
    /// - `chain`: Audio input to track. This must have been pre-analysed by a
    /// 4096 size FFT.
    /// - `keydecay`: Number of seconds for the influence of a window on the
    /// final key decision to decay by 40dB (to 0.01 its original value)
    /// - `chromaleak`: Each frame, the chroma values are set to the previous
    /// value multiplied by the chromadecay. 0.0 will start each frame afresh
    /// with no memory.
    key-track: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, keydecay: ugen-input, chromaleak: ugen-input) -> ugen-input;

    /// Klang is a bank of fixed frequency sine oscillators. Klang is more
    /// efficient than creating individual oscillators but offers less
    /// flexibility. The specs can't be changed after it has been started. For a
    /// modulatable but less efficient version, see dyn-klang.
    /// 
    /// Args:
    /// - `specs`: An array of three arrays frequencies, amplitudes and phases:
    /// 1) an array of filter frequencies, 2) an Array of filter amplitudes, or
    /// nil. If nil, then amplitudes default to 1.0, 3) an Array of initial
    /// phases, or nil. If nil, then phases default to 0.0.
    /// - `freqscale`: a scale factor multiplied by all frequencies at
    /// initialization time.
    /// - `freqoffset`: an offset added to all frequencies at initialization
    /// time.
    klang: func(def: borrow<synth-def>, ugen-rate: rate, specs: ugen-input, freqscale: ugen-input, freqoffset: ugen-input) -> ugen-input;

    /// Klank is a bank of fixed frequency resonators which can be used to
    /// simulate the resonant modes of an object. Each mode is given a ring
    /// time, which is the time for the mode to decay by 60 dB. The specs can't
    /// be changed after it has been started. For a modulatable but less
    /// efficient version, see dyn-klank.
    /// 
    /// Args:
    /// - `specs`: An array of three arrays: frequencies, amplitudes and ring
    /// times: *all arrays should have the same length* 1) an Array of filter
    /// frequencies. 2) an Array of filter amplitudes, or nil. If nil, then
    /// amplitudes default to 1.0 3) an Array of 60 dB decay times for the
    /// filters.
    /// - `input`: the excitation input to the resonant filter bank.
    /// - `freqscale`: a scale factor multiplied by all frequencies at
    /// initialization time.
    /// - `freqoffset`: an offset added to all frequencies at initialization
    /// time.
    /// - `decayscale`: a scale factor multiplied by all ring times at
    /// initialization time.
    klank: func(def: borrow<synth-def>, ugen-rate: rate, specs: ugen-input, input: ugen-input, freqscale: ugen-input, freqoffset: ugen-input, decayscale: ugen-input) -> ugen-input;

    /// Randomly generates the values -1 or +1 at a rate given by the nearest
    /// integer division of the sample rate by the freq argument. It is probably
    /// pretty hard on your speakers!
    /// 
    /// Args:
    /// - `freq`: approximate rate at which to generate random values.
    lf-clip-noise: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// an oscillator outputting a sine like shape made of two cubic pieces
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset. For efficiency reasons this is a value
    /// ranging from 0 to 2.
    lf-cub: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input) -> ugen-input;

    /// Like lf-clip-noise, it generates the values -1 or +1 at a rate given by
    /// the freq argument, with two differences: * no time quantization * fast
    /// recovery from low freq values. (lf-clip-noise, as well as lf-noise0,1,2
    /// quantize to the nearest integer division of the samplerate, and they
    /// poll the freq argument only when scheduled; thus they often seem to hang
    /// when freqs get very low). If you don't need very high or very low freqs,
    /// or use fixed freqs lf-noise0 is more efficient.
    /// 
    /// Args:
    /// - `freq`: rate at which to generate random values.
    lfd-clip-noise: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Like lf-noise0, it generates random values between -1 and 1 at a rate
    /// given by the freq argument, with two differences: p * no time
    /// quantization * fast recovery from low freq values. (lf-noise0,1,2
    /// quantize to the nearest integer division of the samplerate and they poll
    /// the freq argument only when scheduled, and thus seem to hang when freqs
    /// get very low). If you don't need very high or very low freqs, or use
    /// fixed freqs lf-noise0 is more efficient.
    /// 
    /// Args:
    /// - `freq`: rate at which to generate random values.
    lfd-noise0: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Like lf-noise1, it generates linearly interpolated random values between
    /// -1 and 1 at a rate given by the freq argument, with two differences: *
    /// no time quantization * fast recovery from low freq values.
    /// (lf-noise0,1,2 quantize to the nearest integer division of the
    /// samplerate and they poll the freq argument only when scheduled, and thus
    /// seem to hang when freqs get very low). If you don't need very high or
    /// very low freqs, or use fixed freqs lf-noise1 is more efficient.
    /// 
    /// Args:
    /// - `freq`: rate at which to generate random values.
    lfd-noise1: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Similar to lf-noise2, it generates polynomially interpolated random
    /// values between -1 and 1 at a rate given by the freq argument, with 3
    /// differences: * no time quantization * fast recovery from low freq values
    /// * cubic instead of quadratic interpolation (lf-noise0,1,2 quantize to
    /// the nearest integer division of the samplerate and they poll the freq
    /// argument only when scheduled, and thus seem to hang when freqs get very
    /// low). If you don't need very high or very low freqs, or use fixed freqs
    /// lf-noise2 is more efficient.
    /// 
    /// Args:
    /// - `freq`: rate at which to generate random values.
    lfd-noise3: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// A non-band-limited gaussian function oscillator. Output ranges from
    /// minval to 1. LFGauss implements the formula: f(x) = exp(squared(x -
    /// iphase) / (-2.0 * squared(width))) where x is to vary in the range -1 to
    /// 1 over the period dur. minval is the initial value at -1
    /// 
    /// Args:
    /// - `duration`: Duration of one full cycle ( for freq input: dur = 1 /
    /// freq )
    /// - `width`: Relative width of the bell. Best to keep below 0.25 when used
    /// as envelope.
    /// - `iphase`: Initial offset
    /// - `loop`: If loop is > 0, UGen oscillates. Otherwise it calls the done
    /// action after one cycle
    /// - `action`: Action to be evaluated after cycle completes. Default:
    /// NO-ACTION.
    lf-gauss: func(def: borrow<synth-def>, ugen-rate: rate, duration: ugen-input, width: ugen-input, iphase: ugen-input, loop: ugen-input, action: ugen-input) -> ugen-input;

    /// Generates random values between -1 and 1 at a rate (the rate is not
    /// guaranteed but approximate)
    /// 
    /// Args:
    /// - `freq`: approximate rate at which to generate random values.
    lf-noise0: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Generates linearly interpolated random values between -1 and 1 at the
    /// supplied rate (the rate is not guaranteed but approximate).
    /// 
    /// Args:
    /// - `freq`: approximate rate at which to generate random values.
    lf-noise1: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Generates quadratically interpolated random values between -1 and 1 at
    /// the supplied rate (the rate is not guaranteed but approximate). Note:
    /// quadratic interpolation means that the noise values can occasionally
    /// extend beyond the normal range of +-1, if the freq varies in certain
    /// ways. If this is undesirable then you might like to clip2 the values or
    /// use a linearly-interpolating unit instead.
    /// 
    /// Args:
    /// - `freq`: approximate rate at which to generate random values.
    lf-noise2: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// a non band-limited parabolic oscillator outputing a high of 1 and a low
    /// of zero.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset. For efficiency reasons this is a value
    /// ranging from 0 to 2.
    lf-par: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input) -> ugen-input;

    /// A non-band-limited pulse oscillator. Outputs a high value of one and a
    /// low value of zero.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset in cycles ( 0..1 )
    /// - `width`: Pulse width duty cycle from zero to one
    lf-pulse: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input, width: ugen-input) -> ugen-input;

    /// low freq (i.e. not band limited) sawtooth oscillator
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset. For efficiency reasons this is a value
    /// ranging from 0 to 2.
    lf-saw: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input) -> ugen-input;

    /// a non-band-limited triangle oscillator
    /// 
    /// The triangle wave shape features two linear slopes and is not as
    /// harmonically rich as a sawtooth wave since it only contains odd
    /// harmonics (partials). Ideally, this type of wave form is mixed with a
    /// sine, square or pulse wave to add a sparkling or bright effect to a
    /// sound and is often employed on pads to give them a glittery feel.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset. For efficiency reasons this is a value
    /// ranging from 0 to 2.
    lf-tri: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input) -> ugen-input;

    /// second order Butterworth low pass filter
    /// 
    /// A low pass filter is a standard subtractive synthesis tool which removes
    /// frequencies above a defined cut-off point. This typically has the effect
    /// of making bright sounds duller. Using a low pass filter allows you to
    /// have fine-grained control of the level of brightness/dullness to tune
    /// your timbre in addition to allowing you to modulate the effect in real
    /// time thus creating movement in the sound.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: cutoff frequency
    lpf: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input) -> ugen-input;

    /// two point average filter. Implements the formula: out(i) = 0.5 * (in(i)
    /// + in(i-1))
    lpz1: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// two zero fixed lowpass. Implements the formula: out(i) = 0.25 * (in(i) +
    /// (2*in(i-1)) + in(i-2))
    lpz2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// exponential lag, useful for smoothing out control signals. This is
    /// essentially the same as OnePole except that instead of supplying the
    /// coefficient directly, it is calculated from a 60 dB lag time. This is
    /// the time required for the filter to converge to within 0.01 % of a
    /// value.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time`: 60 dB lag time in seconds
    lag: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time: ugen-input) -> ugen-input;

    /// equivalent to (lag (lag in time) time), resulting in a smoother
    /// transition. This saves on CPU as you only have to calculate the decay
    /// factor once instead of twice. See lag for more details.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time`: 60 dB lag time in seconds
    lag2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time: ugen-input) -> ugen-input;

    /// equivalent to (lag-ud (lag-ud in up-t down-t) up-t down-t) thus
    /// resulting in a smoother transition. This saves on CPU as you only have
    /// to calculate the decay factor once instead of twice. See Lag for more
    /// details.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time-up`: 60 dB lag time in seconds for the upgoing signal
    /// - `lag-time-down`: 60 dB lag time in seconds for the downgoing signal
    lag2-ud: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time-up: ugen-input, lag-time-down: ugen-input) -> ugen-input;

    /// lag3 is equivalent to (lag (lag (lag in time) time) time), thus
    /// resulting in a smoother transition. This saves on CPU as you only have
    /// to calculate the decay factor once instead of three times. See Lag for
    /// more details.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time`: 60 dB lag time in seconds
    lag3: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time: ugen-input) -> ugen-input;

    /// equivalent to (lag-ud (lag-ud (lag-ud (in up-t down-t) up-t down-t)
    /// up-t, down-t) thus resulting in a smoother transition. This saves on CPU
    /// as you only have to calculate the decay factor once instead of three
    /// times.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time-up`: 60 dB lag time in seconds for the upgoing signal
    /// - `lag-time-down`: 60 dB lag time in seconds for the downgoing signal
    lag3-ud: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time-up: ugen-input, lag-time-down: ugen-input) -> ugen-input;

    /// Read a control signal from a bus with a lag.
    /// 
    /// Please document me
    /// 
    /// Args:
    /// - `bus`: the index of the bus to read in from
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. Not modulatable.
    /// - `lag`: lag factor
    lag-in: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, num-channels: u32, lag: ugen-input) -> ugen-input;

    /// the same as Lag except that you can supply a different 60 dB time for
    /// when the signal goes up, from when the signal goes down
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time-up`: 60 dB lag time in seconds for the upgoing signal
    /// - `lag-time-down`: 60 dB lag time in seconds for the downgoing signal
    lag-ud: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time-up: ugen-input, lag-time-down: ugen-input) -> ugen-input;

    /// Output the last value before the input changed
    /// 
    /// Output the last value before the input changed by a threshold of diff
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `diff`: difference threshold
    last-value: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, diff: ugen-input) -> ugen-input;

    /// Sample and hold
    /// 
    /// Holds input signal value when triggered.
    /// 
    /// Args:
    /// - `%in`: Input signal.
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    latch: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig: ugen-input) -> ugen-input;

    /// a cubic-interpolating (latoocarfian chaotic) sound generator. Parameters
    /// a and b should be in the range from -3 to +3, and parameters c and d
    /// should be in the range from 0.5 to 1.5. The function can, depending on
    /// the parameters given, give continuous chaotic output, converge to a
    /// single value (silence) or oscillate in a cycle (tone).
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `d`: 4th coefficient
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    latoocarfian-c: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, d: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// a linear-interpolating (latoocarfian chaotic) sound generator.
    /// Parameters a and b should be in the range from -3 to +3, and parameters
    /// c and d should be in the range from 0.5 to 1.5. The function can,
    /// depending on the parameters given, give continuous chaotic output,
    /// converge to a single value (silence) or oscillate in a cycle (tone).
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `d`: 4th coefficient
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    latoocarfian-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, d: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// a non-interpolating (latoocarfian chaotic) sound generator. Parameters a
    /// and b should be in the range from -3 to +3, and parameters c and d
    /// should be in the range from 0.5 to 1.5. The function can, depending on
    /// the parameters given, give continuous chaotic output, converge to a
    /// single value (silence) or oscillate in a cycle (tone).
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `d`: 4th coefficient
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    latoocarfian-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, d: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// removes a DC offset from signal. For example, a square wave contains
    /// prolonged sections of the cycle which are at +1 and -1 (the top and
    /// bottom of the square sections). If you were to pass this wave through
    /// leak-dc, then these top parts would taper back towards 0 with a greater
    /// slope as you move coef from 1 to 0.. Good starting point coef values are
    /// to 0.995 for audio rate and 0.9 for control rate
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `coef`: leak coefficient. A value of 1 indicates no leakage and 0
    /// indicates high leakage - essentially the rate at which the offset will
    /// return back to 0
    leak-dc: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, coef: ugen-input) -> ugen-input;

    /// Output least changed
    /// 
    /// output whichever signal changed the least
    /// 
    /// Args:
    /// - `a`: first input
    /// - `b`: second input
    least-change: func(def: borrow<synth-def>, ugen-rate: rate, a: ugen-input, b: ugen-input) -> ugen-input;

    /// Limits the input amplitude to the given level. Limiter will not
    /// overshoot like Compander will, but it needs to look ahead in the audio.
    /// Thus there is a delay equal to twice the lookAheadTime. Limiter, unlike
    /// Compander, is completely transparent for an in range signal.
    /// 
    /// Args:
    /// - `%in`: The input signal
    /// - `level`: The peak output amplitude level to which to normalize the
    /// input
    /// - `dur`: The buffer delay time. Shorter times will produce smaller
    /// delays and quicker transient response times, but may introduce amplitude
    /// modulation artifacts. (AKA lookAheadTime)
    limiter: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, level: ugen-input, dur: ugen-input) -> ugen-input;

    /// a cubic-interpolating (linear congruential chaotic) sound generator. The
    /// output signal is automatically scaled to a range of [-1, 1].
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz.
    /// - `a`: multiplier amount
    /// - `c`: increment amount
    /// - `m`: modulus amount
    /// - `xi`: initial value of x
    lin-cong-c: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, c: ugen-input, m: ugen-input, xi: ugen-input) -> ugen-input;

    /// a linear-interpolating (linear congruential chaotic) sound generator.
    /// The output signal is automatically scaled to a range of [-1, 1].
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz.
    /// - `a`: multiplier amount
    /// - `c`: increment amount
    /// - `m`: modulus amount
    /// - `xi`: initial value of x
    lin-cong-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, c: ugen-input, m: ugen-input, xi: ugen-input) -> ugen-input;

    /// a non-interpolating (linear congruential chaotic) sound generator. The
    /// output signal is automatically scaled to a range of [-1, 1].
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz.
    /// - `a`: multiplier amount
    /// - `c`: increment amount
    /// - `m`: modulus amount
    /// - `xi`: initial value of x
    lin-cong-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, c: ugen-input, m: ugen-input, xi: ugen-input) -> ugen-input;

    /// Map a linear range to an exponential range
    /// 
    /// Convert from a linear range to an exponential range. The dstlo and dsthi
    /// arguments must be nonzero and have the same sign.
    /// 
    /// Args:
    /// - `%in`: Input to convert
    /// - `srclo`: Lower limit of input range
    /// - `srchi`: Upper limit of input range
    /// - `dstlo`: Lower limit of output range
    /// - `dsthi`: Upper limit of output range
    lin-exp: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, srclo: ugen-input, srchi: ugen-input, dstlo: ugen-input, dsthi: ugen-input) -> ugen-input;

    /// Two channel (stereo) linear panner. This one sounds more like the Rhodes
    /// tremolo than Pan2.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `pos`: pan position, -1 is left, +1 is right
    /// - `level`: a control rate level input
    lin-pan2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, pos: ugen-input, level: ugen-input) -> ugen-input;

    /// Generates a single random float value in linear distribution from lo to
    /// hi, skewed towards lo if minmax < 0, otherwise skewed towards hi.
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated float
    /// - `hi`: Maximum value of generated float
    /// - `minmax`: Skew direction (towards lo if negative otherwise hi)
    lin-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input, minmax: ugen-input) -> ugen-input;

    /// Two channel linear crossfader.
    /// 
    /// Args:
    /// - `in-a`: input signal A
    /// - `in-b`: input signal B
    /// - `pan`: cross fade position from -1 to +1
    /// - `level`: a control rate level input
    lin-x-fade2: func(def: borrow<synth-def>, ugen-rate: rate, in-a: ugen-input, in-b: ugen-input, pan: ugen-input, level: ugen-input) -> ugen-input;

    /// Line generator.
    /// 
    /// Generates a line from the start value to the end value.
    /// 
    /// Args:
    /// - `start`: Starting value
    /// - `end`: Ending value
    /// - `dur`: Duration in seconds
    /// - `action`: A done action to be evaluated when the line is completed.
    /// Default: NO-ACTION
    line: func(def: borrow<synth-def>, ugen-rate: rate, start: ugen-input, end: ugen-input, dur: ugen-input, action: ugen-input) -> ugen-input;

    /// A linear envelope generator, rises to sus-level over attack-time seconds
    /// and after the gate goes non-positive falls over release-time to finally
    /// perform the (optional) action
    /// 
    /// Args:
    /// - `gate`: Input trigger
    /// - `attack-time`: Time taken to rise to susLevel in seconds
    /// - `sus-level`: Level to hold the envelope at until gate is triggered
    /// - `release-time`: Time to fall from susLevel back to 0 after the gate
    /// has been triggered
    /// - `action`: done action
    linen: func(def: borrow<synth-def>, ugen-rate: rate, gate: ugen-input, attack-time: ugen-input, sus-level: ugen-input, release-time: ugen-input, action: ugen-input) -> ugen-input;

    local-buf: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, num-frames: ugen-input) -> ugen-input;

    /// defines buses that are local to the enclosing synth. These are like the
    /// global buses, but are more convenient if you want to implement a self
    /// contained effect that uses a feedback processing loop. There can only be
    /// one audio rate and one control rate local-in per SynthDef. The audio can
    /// be written to the bus using local-out.
    /// 
    /// Args:
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. The default is 1. You cannot modulate this argument.
    local-in: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32) -> ugen-input;

    /// write to buses local to a synth
    /// 
    /// local-out writes to buses that are local to the enclosing synth. The
    /// buses should have been defined by a local-in ugen. The channelsArray
    /// must be the same number of channels as were declared in the LocalIn.
    /// These are like the global buses, but are more convenient if you want to
    /// implement a self contained effect that uses a feedback processing loop.
    /// 
    /// Args:
    /// - `channels-array`: an Array of channels or single output to write out.
    /// You cannot change the size of this once a SynthDef has been built.
    local-out: func(def: borrow<synth-def>, ugen-rate: rate, channels-array: list<ugen-input>) -> ugen-input;

    /// A noise generator based on the logistic map: y = chaos-param * y * (1.0
    /// - y) y will stay in the range of 0.0 to 1.0 for normal values of the
    /// chaos-param. This leads to a DC offset and may cause a pop when you stop
    /// the Synth. For output you might want to combine this UGen with a LeakDC
    /// or rescale around 0.0 via mul and add: see example below.
    /// 
    /// Args:
    /// - `chaos-param`: a parameter of the chaotic function with useful values
    /// from 0.0 to 4.0. Chaos occurs from 3.57 up. Don't use values outside
    /// this range if you don't want the UGen to blow up.
    /// - `freq`: Frequency of calculation; if over the sampling rate, this is
    /// clamped to the sampling rate
    /// - `init`: Initial value of y (see equation below)
    logistic: func(def: borrow<synth-def>, ugen-rate: rate, chaos-param: ugen-input, freq: ugen-input, init: ugen-input) -> ugen-input;

    /// lorenz chaotic generator. A strange attractor discovered by Edward N.
    /// Lorenz while studying mathematical models of the atmosphere. The time
    /// step amount h determines the rate at which the ODE is evaluated. Higher
    /// values will increase the rate, but cause more instability. A safe choice
    /// is the default amount of 0.05.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `s`: 1st variable
    /// - `r`: 2nd variable
    /// - `b`: 3rd variable
    /// - `h`: integration time stamp
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    /// - `zi`: initial value of z
    lorenz-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, s: ugen-input, r: ugen-input, b: ugen-input, h: ugen-input, xi: ugen-input, yi: ugen-input, zi: ugen-input) -> ugen-input;

    /// A perceptual loudness function which outputs loudness in sones; this is
    /// a variant of an MP3 perceptual model, summing excitation in ERB bands.
    /// It models simple spectral and temporal masking, with equal loudness
    /// contour correction in ERB bands to obtain phons (relative dB), then a
    /// phon to sone transform. The final output is typically in the range of 0
    /// to 64 sones, though higher values can occur with specific synthesised
    /// stimuli.
    /// 
    /// Args:
    /// - `chain`: Audio input to track, which has been pre-analysed by the FFT
    /// UGen
    /// - `smask`: Spectral masking param: lower bins mask higher bin power
    /// within ERB bands, with a power falloff (leaky integration multiplier) of
    /// smask per bin
    /// - `tmask`: Temporal masking param: the phon level let through in an ERB
    /// band is the maximum of the new measurement, and the previous minus tmask
    /// phons
    loudness: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, smask: ugen-input, tmask: ugen-input) -> ugen-input;

    /// Args:
    /// - `chain`: Audio input to track, which has been pre-analysed by the FFT
    /// UGen
    /// - `numcoeff`: Number of coefficients, defaults to 13, maximum of 42
    mfcc: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, numcoeff: ugen-input) -> ugen-input;

    /// Masks off bits in the mantissa of the floating point sample value. This
    /// introduces a quantization noise, but is less severe than linearly
    /// quantizing the signal.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `bits`: the number of mantissa bits to preserve. a number from 0 to
    /// 23.
    mantissa-mask: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, bits: ugen-input) -> ugen-input;

    max-local-bufs: func(def: borrow<synth-def>, ugen-rate: rate, num-local-bufs: ugen-input) -> ugen-input;

    /// returns the median of the last length input points. This non linear
    /// filter is good at reducing impulse noise from a signal.
    /// 
    /// Args:
    /// - `length`: number of input points in which to find the median. Must be
    /// an odd number from 1 to 31. If length is 1 then Median has no effect.
    /// - `%in`: Input signal to be processed
    median: func(def: borrow<synth-def>, ugen-rate: rate, length: ugen-input, %in: ugen-input) -> ugen-input;

    /// attenuates or boosts a frequency band
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: center frequency of the band in Hertz
    /// - `rq`: the reciprocal of Q. bandwidth / cutoffFreq
    /// - `db`: amount of boost (db > 0) or attenuation (db < 0) of the
    /// frequency band
    mid-eq: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, rq: ugen-input, db: ugen-input) -> ugen-input;

    /// A digital implementation of the Moog VCF (filter).
    /// 
    /// Args:
    /// - `%in`: The input signal
    /// - `freq`: The cutoff frequency
    /// - `gain`: The filter resonance gain, between zero and 4
    /// - `reset`: When greater than zero, this will reset the state of the
    /// digital filters at the beginning of a computational block.
    moog-ff: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, gain: ugen-input, reset: ugen-input) -> ugen-input;

    /// Output most changed
    /// 
    /// output whichever signal changed the most
    /// 
    /// Args:
    /// - `a`: first input
    /// - `b`: second input
    most-change: func(def: borrow<synth-def>, ugen-rate: rate, a: ugen-input, b: ugen-input) -> ugen-input;

    /// toggles between two values when the left mouse button is up or down
    /// 
    /// Args:
    /// - `up`: value when the key is not pressed
    /// - `down`: value when the key is pressed
    /// - `lag`: lag factor
    mouse-button: func(def: borrow<synth-def>, ugen-rate: rate, up: ugen-input, down: ugen-input, lag: ugen-input) -> ugen-input;

    /// maps the current mouse X coordinate to a value between min and max
    /// 
    /// Args:
    /// - `min`: minimum value (when mouse is at the left of the screen)
    /// - `max`: maximum value (when mouse is at the right of the screen)
    /// - `warp`: mapping curve - either LINEAR or EXPONENTIAL (LIN and EXP
    /// abbreviations are allowed). Default is LINEAR.
    /// - `lag`: lag factor to dezipper cursor movement.
    mouse-x: func(def: borrow<synth-def>, ugen-rate: rate, min: ugen-input, max: ugen-input, warp: ugen-input, lag: ugen-input) -> ugen-input;

    /// maps the current mouse Y coordinate to a value between min and max
    /// 
    /// Args:
    /// - `min`: minimum value (when mouse is at the top of the screen)
    /// - `max`: maximum value (when mouse is at the bottom of the screen)
    /// - `warp`: mapping curve - either LINEAR or EXPONENTIAL (LIN and EXP
    /// abbreviations are allowed). Default is LINEAR
    /// - `lag`: lag factor to smooth out cursor movement.
    mouse-y: func(def: borrow<synth-def>, ugen-rate: rate, min: ugen-input, max: ugen-input, warp: ugen-input, lag: ugen-input) -> ugen-input;

    /// Multiply the input source by mul then add the add value. Equivalent to,
    /// but more efficient than, (+ add (* mul in))
    /// 
    /// Args:
    /// - `%in`: Input to modify
    /// - `mul`: Multiplier Value
    /// - `add`: Addition Value
    mul-add: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, mul: ugen-input, add: ugen-input) -> ugen-input;

    /// Generates a single random float value in a sum of n uniform
    /// distributions from lo to hi. n = 1 : uniform distribution - same as Rand
    /// n = 2 : triangular distribution n = 3 : smooth hump As n increases,
    /// distribution converges towards gaussian
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated float
    /// - `hi`: Maximum value of generated float
    /// - `n`: Distribution choice
    n-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input, n: ugen-input) -> ugen-input;

    /// flattens dynamics. Normalizes the input amplitude to the given level.
    /// Normalize will not overshoot like Compander will, but it needs to look
    /// ahead in the audio. Thus there is a delay equal to twice the
    /// lookAheadTime.
    /// 
    /// Args:
    /// - `%in`: The input signal
    /// - `level`: The peak output amplitude level to which to normalize the
    /// input
    /// - `dur`: The buffer delay time. Shorter times will produce smaller
    /// delays and quicker transient response times, but may introduce amplitude
    /// modulation artifacts. (AKA lookAheadTime)
    normalizer: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, level: ugen-input, dur: ugen-input) -> ugen-input;

    /// returns the number of audio buses allocated on the server.
    num-audio-buses: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the number of buffers allocated on the server
    num-buffers: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the number of control buses allocated on the server
    num-control-buses: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the number of input buses allocated on the server. This is the
    /// number of hardware inputs provided by the host machine such as a mic.
    num-input-buses: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the number of output buses allocated on the server. This is the
    /// number of hardware outputs provided by the host machine such as left and
    /// right speakers.
    num-output-buses: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the number of currently running synths
    num-running-synths: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// write signal to a bus with sample accurate timing
    /// 
    /// Output signal to a bus, the sample offset within the bus is kept
    /// exactly; i.e. if the synth is scheduled to be started part way through a
    /// control cycle, offset-out will maintain the correct offset by buffering
    /// the output and delaying it until the exact time that the synth was
    /// scheduled for. This ugen is used where sample accurate output is needed.
    /// 
    /// Args:
    /// - `bus`: the index of the buss to write to. The lowest index numbers are
    /// written to the audio hardware.
    /// - `channels-array`: a list of signals or single output to write out. You
    /// cannot change the size of this once a synth has been defined.
    offset-out: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// A one pole filter. Implements the formula: out(i) = ((1 - abs(coef)) *
    /// in(i)) + (coef * out(i-1))
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `coef`: feedback coefficient. Should be between -1 and +1
    one-pole: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, coef: ugen-input) -> ugen-input;

    /// A one zero filter. Implements the formula : out(i) = ((1 - abs(coef)) *
    /// in(i)) + (coef * in(i-1))
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `coef`: feed forward coefficient. +0.5 makes a two point averaging
    /// filter (see also lpz1), -0.5 makes a differentiator (see also hpz1), +1
    /// makes a single sample delay (see also delay1), -1 makes an inverted
    /// single sample delay.
    one-zero: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, coef: ugen-input) -> ugen-input;

    /// An onset detector for musical audio signals - detects the beginning of
    /// notes/drumbeats/etc. Outputs a control-rate trigger signal which is 1
    /// when an onset is detected, and 0 otherwise. For the FFT chain, you
    /// should typically use a frame size of 512 or 1024 (at 44.1 kHz sampling
    /// rate) and 50% hop size (which is the default setting in SC). For
    /// different sampling rates choose an FFT size to cover a similar time-span
    /// (around 10 to 20 ms). The onset detection should work well for a general
    /// range of monophonic and polyphonic audio signals. The onset detection is
    /// purely based on signal analysis and does not make use of any top-down
    /// inferences such as tempo.
    /// 
    /// Args:
    /// - `chain`: an FFT chain
    /// - `threshold`: the detection threshold, typically between 0 and 1,
    /// although in rare cases you may find values outside this range useful
    /// - `odftype`: the function used to analyse the signal. Options: nPOWER,
    /// MAGSUM, COMPLEX, RCOMPLEX (default), PHASE, WPHASE and MKL. Default is
    /// RCOMPLEX.
    /// - `relaxtime`: specifies the time (in seconds) for the normalisation to
    /// forget about a recent onset. If you find too much re-triggering (e.g. as
    /// a note dies away unevenly) then you might wish to increase this value.
    /// - `floor`: is a lower limit, connected to the idea of how quiet the
    /// sound is expected to get without becoming indistinguishable from noise.
    /// For some cleanly-recorded classical music with wide dynamic variations,
    /// I found it helpful to go down as far as 0.000001.
    /// - `mingap`: specifies a minimum gap (in FFT frames) between onset
    /// detections, a brute-force way to prevent too many doubled detections.
    /// - `medianspan`: specifies the size (in FFT frames) of the median window
    /// used for smoothing the detection function before triggering.
    onsets: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, threshold: ugen-input, odftype: ugen-input, relaxtime: ugen-input, floor: ugen-input, mingap: ugen-input, medianspan: ugen-input, whtype: ugen-input, rawodf: ugen-input) -> ugen-input;

    /// Linear interpolating wavetable lookup oscillator with frequency and
    /// phase modulation inputs. This oscillator requires a buffer to be filled
    /// with a wavetable format signal. This preprocesses the Signal into a form
    /// which can be used efficiently by the Oscillator. The buffer size must be
    /// a power of 2. This can be achieved by creating a Buffer object and
    /// sending it one of the b_gen messages (sine1, sine2, sine3) with the
    /// wavetable flag set to true. This can also be achieved by creating a
    /// Signal object and sending it the 'asWavetable' message, saving it to
    /// disk, and having the server load it from there.
    /// 
    /// Args:
    /// - `buffer`: Lookup buffer
    /// - `freq`: Frequency in Hertz
    /// - `phase`: Phase offset or modulator in radians
    osc: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, freq: ugen-input, phase: ugen-input) -> ugen-input;

    /// write a signal to a bus, adding to previous contents.
    /// 
    /// write a signal to a bus, adding to any existing contents N.B. Out is
    /// subject to control rate jitter. Where sample accurate output is needed,
    /// use OffsetOut. When using an array of bus indexes, the channel array
    /// will just be copied to each bus index in the array. So (out:ar [bus1
    /// bus2] channels-array) will be the same as (+ (out:ar bus1 channelsArray)
    /// (out:ar bus2 channelsArray)).
    /// 
    /// Args:
    /// - `bus`: the index of the buss to write to. The lowest index numbers are
    /// written to the audio hardware.
    /// - `channels-array`: a list of signals or single output to write out. You
    /// cannot change the size of this once a synth has been defined.
    %out: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// Fixed frequency sine oscillator this ugen uses a very fast algorithm for
    /// generating a sine wave at a fixed frequency
    /// 
    /// Args:
    /// - `freq`: frequency in cycles per second. Must be a scalar
    /// - `dur`: grain duration
    /// - `amp`: amplitude of grain
    p-sin-grain: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, dur: ugen-input, amp: ugen-input) -> ugen-input;

    /// complex addition: RealA + RealB, ImagA + ImagB
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-add: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// randomizes the order of the bins. The trigger will select a new random
    /// ordering.
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `wipe`: scrambles more bins as wipe moves from zero to one.
    /// - `width`: a value from zero to one, indicating the maximum randomized
    /// distance of a bin from its original location in the spectrum.
    /// - `trig`: a trigger selects a new random ordering.
    pv-bin-scramble: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, wipe: ugen-input, width: ugen-input, trig: ugen-input) -> ugen-input;

    /// shift and scale the positions of the bins. Can be used as a very crude
    /// frequency shifter/scaler.
    /// 
    /// Args:
    /// - `buffer`: fft buffer.
    /// - `stretch`: scale bin location by factor.
    /// - `shift`: add an offset to bin position.
    pv-bin-shift: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, stretch: ugen-input, shift: ugen-input) -> ugen-input;

    /// copies low bins from one input and the high bins of the other
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    /// - `wipe`: can range between -1 and +1; if wipe == 0 then the output is
    /// the same as inA; if wipe > 0 then it begins replacing with bins from inB
    /// from the bottom up;if wipe < 0 then it begins replacing with bins from
    /// inB from the top down.
    pv-bin-wipe: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input, wipe: ugen-input) -> ugen-input;

    /// clears bins above or below a cutoff point
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `wipe`: can range between -1 and +1. if wipe == 0 then there is no
    /// effect; if wipe > 0 then it acts like a high pass filter, clearing bins
    /// from the bottom up; if wipe < 0 then it acts like a low pass filter,
    /// clearing bins from the top down.
    pv-brick-wall: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, wipe: ugen-input) -> ugen-input;

    /// Applies the conformal mapping z -> (z-a)/(1-za*) to the phase vocoder
    /// bins z with a given by the real and imag inputs to the UGen. i.e., makes
    /// a transformation of the complex plane so the output is full of phase
    /// vocoder artifacts but may be musically fun. Usually keep |a|<1 but you
    /// can of course try bigger values to make it really noisy. a=0 should give
    /// back the input mostly unperturbed. See
    /// http://mathworld.wolfram.com/ConformalMapping.html
    /// 
    /// Args:
    /// - `buffer`: buffer number of buffer to act on, passed in through a chain
    /// (see examples below).
    /// - `areal`: real part of a.
    /// - `aimag`: imaginary part of a.
    pv-conformal-map: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, areal: ugen-input, aimag: ugen-input) -> ugen-input;

    /// converts the FFT frames to their complex conjugate (i.e. reverses the
    /// sign of their imaginary part). This is not usually a useful audio effect
    /// in itself, but may be a component of other analysis or transformation
    /// processes...
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    pv-conj: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input) -> ugen-input;

    /// copies the spectral frame in bufferA to bufferB at that point in the
    /// chain of PV UGens. This allows for parallel processing of spectral data
    /// without the need for multiple FFT UGens, and to copy out data at that
    /// point in the chain for other purposes. bufferA and bufferB must be the
    /// same size.
    /// 
    /// Args:
    /// - `buffer-a`: source buffer
    /// - `buffer-b`: destination buffer
    pv-copy: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// combines magnitudes of first input and phases of the second input
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-copy-phase: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// adds a different constant random phase shift to each bin. The trigger
    /// will select a new set of random phases.
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `trig`: a trigger selects a new set of random values.
    pv-diffuser: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, trig: ugen-input) -> ugen-input;

    /// complex division
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-div: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// FFT onset detector based on work described in: Hainsworth, S. (2003)
    /// Techniques for the Automated Analysis of Musical Audio. PhD, University
    /// of Cambridge engineering dept. See especially p128. The Hainsworth
    /// metric is a modification of the Kullback Liebler distance. The onset
    /// detector has general ability to spot spectral change, so may have some
    /// ability to track chord changes aside from obvious transient jolts, but
    /// there's no guarantee it won't be confused by frequency modulation
    /// artifacts. Hainsworth metric on it's own gives good results but Foote
    /// might be useful in some situations: experimental.
    /// 
    /// Args:
    /// - `buffer`: FFT buffer to read from
    /// - `proph`: What strength of detection signal from Hainsworth metric to
    /// use.
    /// - `propf`: What strength of detection signal from Foote metric to use.
    /// The Foote metric is normalised to [0.0,1.0]
    /// - `threshold`: Threshold hold level for allowing a detection
    /// - `wait-time`: If triggered, minimum wait until a further frame can
    /// cause another spot (useful to stop multiple detects on heavy signals)
    pv-hainsworth-foote: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, proph: ugen-input, propf: ugen-input, threshold: ugen-input, wait-time: ugen-input) -> ugen-input;

    /// FFT feature detector for onset detection based on work described in:
    /// Jensen,K. & Andersen, T. H. (2003). Real-time Beat Estimation Using
    /// Feature Extraction. In Proceedings of the Computer Music Modeling and
    /// Retrieval Symposium, Lecture Notes in Computer Science. Springer Verlag.
    /// First order derivatives of the features are taken. Threshold may need to
    /// be set low to pick up on changes.
    /// 
    /// Args:
    /// - `buffer`: FFT buffer to read from.
    /// - `propsc`: Proportion of spectral centroid feature.
    /// - `prophfe`: Proportion of high frequency energy feature.
    /// - `prophfc`: Proportion of high frequency content feature.
    /// - `propsf`: Proportion of spectral flux feature.
    /// - `threshold`: Threshold level for allowing a detection
    /// - `wait-time`: If triggered, minimum wait until a further frame can
    /// cause another spot (useful to stop multiple detects on heavy signals)
    pv-jensen-andersen: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, propsc: ugen-input, prophfe: ugen-input, prophfc: ugen-input, propsf: ugen-input, threshold: ugen-input, wait-time: ugen-input) -> ugen-input;

    /// passes only bins whose magnitude is above a threshold and above their
    /// nearest neighbors
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `threshold`: magnitude threshold.
    pv-local-max: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, threshold: ugen-input) -> ugen-input;

    /// passes only bins whose magnitude is above a threshold
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `threshold`: magnitude threshold.
    pv-mag-above: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, threshold: ugen-input) -> ugen-input;

    /// passes only bins whose magnitude is below a threshold
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `threshold`: magnitude threshold.
    pv-mag-below: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, threshold: ugen-input) -> ugen-input;

    /// clips bin magnitudes to a maximum threshold
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `threshold`: magnitude threshold.
    pv-mag-clip: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, threshold: ugen-input) -> ugen-input;

    /// divides magnitudes of two inputs and keeps the phases of the first input
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A.
    /// - `buffer-b`: fft buffer B.
    /// - `zeroed`: number to use when bins are zeroed out, i.e. causing
    /// division by zero
    pv-mag-div: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input, zeroed: ugen-input) -> ugen-input;

    /// freezes magnitudes at current levels when freeze > 0
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `freeze`: if freeze > 0 then magnitudes are frozen at current levels.
    pv-mag-freeze: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, freeze: ugen-input) -> ugen-input;

    /// multiplies magnitudes of two inputs and keeps the phases of the first
    /// input
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-mag-mul: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// magnitudes are multiplied with noise
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    pv-mag-noise: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input) -> ugen-input;

    /// shift and stretch the positions of only the magnitude of the bins. Can
    /// be used as a very crude frequency shifter/scaler.
    /// 
    /// Args:
    /// - `buffer`: fft buffer.
    /// - `stretch`: scale bin location by factor.
    /// - `shift`: add an offset to bin position.
    pv-mag-shift: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, stretch: ugen-input, shift: ugen-input) -> ugen-input;

    /// average a bin's magnitude with its neighbors
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `bins`: number of bins to average on each side of bin. As this number
    /// rises, so will CPU usage.
    pv-mag-smear: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, bins: ugen-input) -> ugen-input;

    /// squares the magnitudes and renormalizes to previous peak. This makes
    /// weak bins weaker.
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    pv-mag-squared: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input) -> ugen-input;

    /// output copies bins with the maximum magnitude of the two inputs
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-max: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// output copies bins with the minimum magnitude of the two inputs
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-min: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// complex multiplication: (RealA * RealB) - (ImagA * ImagB) (ImagA *
    /// RealB) + (RealA * ImagB)
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A
    /// - `buffer-b`: fft buffer B
    pv-mul: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input) -> ugen-input;

    /// shift phase of all bins
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    /// - `shift`: phase shift in radians
    pv-phase-shift: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, shift: ugen-input) -> ugen-input;

    /// shift phase of all bins by 270 degrees
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    pv-phase-shift270: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input) -> ugen-input;

    /// shift phase of all bins by 90 degrees
    /// 
    /// Args:
    /// - `buffer`: fft buffer
    pv-phase-shift90: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input) -> ugen-input;

    /// randomly clear bins
    /// 
    /// Args:
    /// - `buffer`: fft buffer.
    /// - `wipe`: clears bins from input in a random order as wipe goes from 0
    /// to 1.
    /// - `trig`: a trigger selects a new random ordering.
    pv-rand-comb: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, wipe: ugen-input, trig: ugen-input) -> ugen-input;

    /// cross fades between two sounds by copying bins in a random order
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A.
    /// - `buffer-b`: fft buffer B.
    /// - `wipe`: copies bins from bufferB in a random order as wipe goes from 0
    /// to 1.
    /// - `trig`: a trigger selects a new random ordering.
    pv-rand-wipe: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input, wipe: ugen-input, trig: ugen-input) -> ugen-input;

    /// makes a series of gaps in a spectrum
    /// 
    /// Args:
    /// - `buffer`: fft buffer.
    /// - `num-teeth`: number of teeth in the comb.
    /// - `phase`: starting phase of comb pulse.
    /// - `width`: pulse width of comb.
    pv-rect-comb: func(def: borrow<synth-def>, ugen-rate: rate, buffer: ugen-input, num-teeth: ugen-input, phase: ugen-input, width: ugen-input) -> ugen-input;

    /// alternates blocks of bins between the two inputs
    /// 
    /// Args:
    /// - `buffer-a`: fft buffer A.
    /// - `buffer-b`: fft buffer B.
    /// - `num-teeth`: number of teeth in the comb.
    /// - `phase`: starting phase of comb pulse.
    /// - `width`: pulse width of comb.
    pv-rect-comb2: func(def: borrow<synth-def>, ugen-rate: rate, buffer-a: ugen-input, buffer-b: ugen-input, num-teeth: ugen-input, phase: ugen-input, width: ugen-input) -> ugen-input;

    /// Two channel (stereo) equal power panner.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `pos`: pan position, -1 is left, +1 is right
    /// - `level`: a control rate level input
    pan2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, pos: ugen-input, level: ugen-input) -> ugen-input;

    /// Four channel equal power panner. Outputs are in order LeftFront,
    /// RightFront, LeftBack, RightBack.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `xpos`: x pan position from -1 to +1 (left to right)
    /// - `ypos`: y pan position from -1 to +1 (back to front)
    /// - `level`: a control rate level input.
    pan4: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, xpos: ugen-input, ypos: ugen-input, level: ugen-input) -> ugen-input;

    /// Multichannel equal power panner.
    /// 
    /// Args:
    /// - `num-channels`: number of output channels
    /// - `%in`: input signal
    /// - `pos`: pan position. Channels are evenly spaced over a cyclic period
    /// of 2.0 with 0.0 equal to the position directly in front, 2.0/numChans a
    /// clockwise shift 1/numChans of the way around the ring, 4.0/numChans
    /// equal to a shift of 2/numChans, etc. Thus all channels will be
    /// cyclically panned through if a sawtooth wave from -1 to +1 is used to
    /// modulate the pos. N.B. Front may or may not correspond to a speaker
    /// depending on the setting of the orientation arg, see below.
    /// - `level`: a control rate level input.
    /// - `width`: The width of the panning envelope. Nominally this is 2.0
    /// which pans between pairs of adjacent speakers. Width values greater than
    /// two will spread the pan over greater numbers of speakers. Width values
    /// less than one will leave silent gaps between speakers.
    /// - `orientation`: Should be zero if the front is a vertex of the polygon.
    /// The first speaker will be directly in front. Should be 0.5 if the front
    /// bisects a side of the polygon. Then the first speaker will be the one
    /// left of center. Default is 0.5.
    pan-az: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, %in: ugen-input, pos: ugen-input, level: ugen-input, width: ugen-input, orientation: ugen-input) -> ugen-input;

    /// Ambisonic B format panner. Output channels are in order W,X,Y,Z.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `azimuth`: in radians, -pi to +pi
    /// - `elevation`: in radians, -0.5pi to +0.5pi
    /// - `gain`: a control rate level input
    pan-b: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, azimuth: ugen-input, elevation: ugen-input, gain: ugen-input) -> ugen-input;

    /// Encode a mono signal to two dimensional ambisonic B-format.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `azimuth`: position around the circle from -1 to +1. -1 is behind,
    /// -0.5 is left, 0 is forward, +0.5 is right, +1 is behind.
    /// - `gain`: amplitude control
    pan-b2: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, azimuth: ugen-input, gain: ugen-input) -> ugen-input;

    /// Partitioned convolution. Various additional buffers must be supplied.
    /// Mono impulse response only! If inputting multiple channels, you'll need
    /// independent PartConvs, one for each channel. But the charm is: impulse
    /// response can be as large as you like (CPU load increases with IR size.
    /// Various tradeoffs based on fftsize choice, due to rarer but larger FFTs.
    /// This plug-in uses amortisation to spread processing and avoid spikes).
    /// Normalisation factors difficult to anticipate; convolution piles up
    /// multiple copies of the input on top of itself, so can easily overload.
    /// 
    /// Args:
    /// - `%in`: Processing target.
    /// - `fftsize`: Spectral convolution partition size (twice partition size).
    /// You must ensure that the blocksize divides the partition size and there
    /// are at least two blocks per partition (to allow for amortisation)
    /// - `irbufnum`: Prepared buffer of spectra for each partition of the
    /// inpulse response
    part-conv: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, fftsize: ugen-input, irbufnum: ugen-input) -> ugen-input;

    /// Pause a specified node when triggered
    /// 
    /// Args:
    /// - `gate`: when gate is 0, node is paused, when 1 it runs
    /// - `id`: node to be paused
    pause: func(def: borrow<synth-def>, ugen-rate: rate, gate: ugen-input, id: ugen-input) -> ugen-input;

    /// Pause the enclosing synth when triggered
    /// 
    /// Args:
    /// - `%in`: input signal
    pause-self: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Pause the enclosing synth when the src ugen finishes (e.g. env-gen,
    /// play-buf, linen...)
    /// 
    /// Args:
    /// - `src`: the ugen to check for done
    pause-self-when-done: func(def: borrow<synth-def>, ugen-rate: rate, src: ugen-input) -> ugen-input;

    /// Track peak signal amplitude
    /// 
    /// Outputs the peak amplitude of the signal so far, a trigger resets to
    /// current value
    /// 
    /// Args:
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `reset`: Resets the counter to zero when triggered.
    peak: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, reset: ugen-input) -> ugen-input;

    /// Track peak signal amplitude
    /// 
    /// Outputs the peak signal amplitude, falling with decay over time until
    /// reaching signal level
    /// 
    /// Args:
    /// - `%in`: input signal.
    /// - `decay`: decay factor.
    peak-follower: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, decay: ugen-input) -> ugen-input;

    /// Resettable linear ramp between two levels
    /// 
    /// Phasor is a linear ramp between start and end values. When its trigger
    /// input crosses from non-positive to positive, Phasor's output will jump
    /// to its reset position. Upon reaching the end of its ramp Phasor will
    /// wrap back to its start. N.B. Since end is defined as the wrap point, its
    /// value is never actually output.
    /// 
    /// Args:
    /// - `trig`: When triggered, reset value to reset-pos (default: 0, phasor
    /// outputs start initially)
    /// - `rate`: The amount of change per sample i.e at a rate of 1 the value
    /// of each sample will be 1 greater than the preceding sample
    /// - `start`: Starting point of the ramp
    /// - `end`: End point of the ramp
    /// - `reset-pos`: The value to jump to upon receiving a trigger
    phasor: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, rate: ugen-input, start: ugen-input, end: ugen-input, reset-pos: ugen-input) -> ugen-input;

    /// Noise whose spectrum falls off in power by 3 dB per octave.
    /// 
    /// Noise that gives equal power over the span of each octave. Useful for
    /// generating percussive sounds such as snares and hand claps. Also useful
    /// for simulating wind or sea effects, for producing breath effects in wind
    /// instrument timbres or for producing the typical trance leads. This
    /// version gives 8 octaves of pink noise.
    pink-noise: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// Autocorrelation pitch follower
    /// 
    /// This is a better pitch follower than zero-crossing, but more costly of
    /// CPU. For most purposes the default settings can be used and only in
    /// needs to be supplied. Pitch returns two values (via an Array of
    /// OutputProxys, a freq which is the pitch estimate and has-freq, which
    /// tells whether a pitch was found. Some vowels are still problematic, for
    /// instance a wide open mouth sound somewhere between a low pitched short
    /// 'a' sound as in 'sat', and long 'i' sound as in 'fire', contains enough
    /// overtone energy to confuse the algorithm. None of these settings are
    /// time variable.
    /// 
    /// Args:
    /// - `%in`: Input signal
    /// - `init-freq`: Value of output pitch until first pitch detected.
    /// - `min-freq`: Minimum frequency of execution.
    /// - `max-freq`: Maximum frequency of execution.
    /// - `exec-freq`: The target rate to periodically execute in cps. Clipped
    /// between min-freq and max-freq.
    /// - `max-bins-per-octave`: Number of lags for course search. A larger
    /// value will cause the coarse search to take longer, a smaller value will
    /// cause the subsequent fine search to take longer.
    /// - `median`: Median filter value of length median on the output
    /// estimation. Helps eliminate outliers and jitter. Value of 1 means no
    /// filter.
    /// - `amp-threshold`: Minum peak to peak amplitude of input signal before
    /// pitch estimation is performed.
    /// - `peak-threshold`: Finds the next peak that is above peak-threshold
    /// times the amplitude of the peak at lag zero. A value of 0.5 does a
    /// pretty good job of eliminating overtones.
    /// - `down-sample`: Down sample the input signal by an integer factor.
    /// Helps reduce CPU overthead. Also reduces pitch resolution.
    /// - `clar`: Clarity measurement (purity of the pitched signal) if greater
    /// than 0.
    pitch: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, init-freq: ugen-input, min-freq: ugen-input, max-freq: ugen-input, exec-freq: ugen-input, max-bins-per-octave: ugen-input, median: ugen-input, amp-threshold: ugen-input, peak-threshold: ugen-input, down-sample: ugen-input, clar: ugen-input) -> ugen-input;

    /// A time domain granular pitch shifter. Grains have a triangular amplitude
    /// envelope and an overlap of 4:1.
    /// 
    /// Args:
    /// - `%in`: The input signal.
    /// - `window-size`: The size of the grain window in seconds. This value
    /// cannot be modulated.
    /// - `pitch-ratio`: The ratio of the pitch shift. Must be from 0.0 to 4.0
    /// - `pitch-dispersion`: The maximum random deviation of the pitch from the
    /// pitchRatio.
    /// - `time-dispersion`: A random offset of from zero to timeDispersion
    /// seconds is added to the delay of each grain. Use of some dispersion can
    /// alleviate a hard comb filter effect due to uniform grain placement. It
    /// can also be an effect in itself. timeDispersion can be no larger than
    /// windowSize.
    pitch-shift: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, window-size: ugen-input, pitch-ratio: ugen-input, pitch-dispersion: ugen-input, time-dispersion: ugen-input) -> ugen-input;

    /// Plays back a sample resident in a buffer
    /// 
    /// Args:
    /// - `num-channels`: The number of channels that the buffer will be. This
    /// must be a fixed integer. The architechture of the SynthDef cannot change
    /// after it is compiled. Warning: if you supply a bufnum of a buffer that
    /// has a different numChannels then you have specified to the play-buf, it
    /// will fail silently.
    /// - `bufnum`: The index of the buffer to use.
    /// - `rate`: 1.0 is the server's sample rate, 2.0 is one octave up, 0.5 is
    /// one octave down -1.0 is backwards normal rate ... etc. Interpolation is
    /// cubic. Note: if the buffer's sample rate is different from the server's,
    /// you will need to multiply the desired playback rate by (file's rate /
    /// server's rate). The UGen (buf-rate-scale bufnum) returns this factor.
    /// - `trigger`: A trigger causes a jump to the startPos. A trigger occurs
    /// when a signal changes from <= 0 to > 0.
    /// - `start-pos`: Sample frame to start playback.
    /// - `loop`: 1 means true, 0 means false. This is modulateable.
    /// - `action`: an integer representing an action to be executed when the
    /// buffer is finished playing. This can be used to free the enclosing
    /// synth. Action is only evaluated if loop is 0
    play-buf: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, bufnum: ugen-input, rate: ugen-input, trigger: ugen-input, start-pos: ugen-input, loop: ugen-input, action: ugen-input) -> ugen-input;

    /// Implements the Karplus-Strong style of synthesis, where a delay line
    /// (normally starting with noise) is filtered and fed back on itself so
    /// that over time it becomes periodic.
    /// 
    /// Args:
    /// - `%in`: An excitation signal.
    /// - `trig`: Upon a negative to positive transition, the excitation signal
    /// will be fed into the delay line.
    /// - `maxdelaytime`: The max delay time in seconds (initializes the
    /// internal delay buffer).
    /// - `delaytime`: Delay time in seconds.
    /// - `decaytime`: Time for the echoes to decay by 60 decibels. Negative
    /// times emphasize odd partials.
    /// - `coef`: The coef of the internal OnePole filter. Values should be
    /// between -1 and +1 (larger values will be unstable... so be careful!).
    pluck: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig: ugen-input, maxdelaytime: ugen-input, delaytime: ugen-input, decaytime: ugen-input, coef: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the poll cgen instead.
    /// 
    /// Args:
    /// - `trig`: a non-positive to positive transition telling Poll to return a
    /// value
    /// - `%in`: the signal you want to poll
    /// - `label`: a string or symbol to be printed with the polled value
    /// - `trig-id`: if greater than 0, a '/tr' message is sent back to the
    /// client (similar to send-trig)
    poll: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, %in: ugen-input, label: ugen-input, trig-id: ugen-input) -> ugen-input;

    /// band limited pulse wave generator with pulse width modulation.
    /// 
    /// Pulse waves are a general form of square wave that allow for the width
    /// of the pulses to be varied. A square wave is therefore a pulse with a
    /// width of 0.5 i.e. the width of the high and low states is identical.
    /// Adjusting the ratio of the pulse width will vary the harmonic content of
    /// the sound. For example, reductions in the width allow you to produce
    /// thin reed-like timbres along with the wide, hollow sounds created by a
    /// square wave.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz (control rate)
    /// - `width`: Pulse width ratio from zero to one. 0.5 makes a square wave
    /// (control rate)
    pulse: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, width: ugen-input) -> ugen-input;

    /// Pulse counter
    /// 
    /// Each input trigger increments a counter value that is output.
    /// 
    /// Args:
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `reset`: Resets the counter to zero when triggered.
    pulse-count: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, reset: ugen-input) -> ugen-input;

    /// Pulse divider
    /// 
    /// Outputs a trigger every div input triggers
    /// 
    /// Args:
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `div`: Number of pulses to divide by.
    /// - `start-val`: Starting value for the trigger count. This lets you start
    /// somewhere in the middle of a count, or if startCount is negative it adds
    /// that many counts to the first time the output is triggers.
    pulse-divider: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, div: ugen-input, start-val: ugen-input) -> ugen-input;

    /// a cubic-interpolating (general quadratic map chaotic) sound generator
    /// based on the difference equation: xn+1 = axn2 + bxn + c
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `xi`: initial value of x
    quad-c: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, xi: ugen-input) -> ugen-input;

    /// a linear-interpolating (general quadratic map chaotic) sound generator
    /// based on the difference equation: xn+1 = axn2 + bxn + c
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `xi`: initial value of x
    quad-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, xi: ugen-input) -> ugen-input;

    /// a non-interpolating (general quadratic map chaotic) sound generator
    /// based on the difference equation: xn+1 = axn2 + bxn + c
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `a`: 1st coefficient
    /// - `b`: 2nd coefficient
    /// - `c`: 3rd coefficient
    /// - `xi`: initial value of x
    quad-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, xi: ugen-input) -> ugen-input;

    /// resonant high pass filter
    /// 
    /// A resonant high pass filter lets through the frequencies above the
    /// cutoff point and successfully dampens the frequencies below the cutoff
    /// point. This effectively removes the fundamental frequency of the sound,
    /// leaving only the fizz harmonic overtones. However, in addition to this
    /// behaviour, the resonant high pass filter also emphasises/resonates the
    /// frequencies around the cutoff point. The amount of emphasis is
    /// controlled by the rq param with a lower rq resulting in greater
    /// resonance. High amounts of resonance (rq ~0) can create a whistling
    /// sound around the cutoff frequency. High pass filters are rarely used in
    /// the creation of instruments and are predominantly used to create
    /// effervescent sound effects of bright timbres that can be laid over the
    /// top of another low pass sound to increase the harmonic content.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: cutoff frequency
    /// - `rq`: the reciprocal of Q. bandwidth / cutoffFreq. A lower rq results
    /// in more resonance
    rhpf: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, rq: ugen-input) -> ugen-input;

    /// resonant low pass filter
    /// 
    /// A resonant low pass filter is a standard subtractive synthesis tool
    /// which removes frequencies above a defined cut-off point. This typically
    /// has the effect of making bright sounds duller. However, in addition to
    /// this behaviour, the resonant low pass filter also emphasises/resonates
    /// the frequencies around the cutoff point. The amount of emphasis is
    /// controlled by the rq param with a lower rq resulting in greater
    /// resonance. High amounts of resonance (rq ~0) can create a whistling
    /// sound around the cutoff frequency. Using a low pass filter allows you to
    /// have fine-grained control of the level of brightness/dullness to tune
    /// your timbre in addition to allowing you to modulate the effect in real
    /// time thus creating movement in the sound.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: cutoff frequency
    /// - `rq`: the reciprocal of Q. bandwidth / cutoffFreq. A lower rq results
    /// in more resonance.
    rlpf: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, rq: ugen-input) -> ugen-input;

    radians-per-sample: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// similar to lag but with a linear rather than exponential lag, useful for
    /// smoothing out control signals
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lag-time`: 60 dB lag time in seconds
    ramp: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lag-time: ugen-input) -> ugen-input;

    rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// Choose which random number generator to use for this synth. All synths
    /// that use the same generator reproduce the same sequence of numbers when
    /// the same seed is set again.
    /// 
    /// Args:
    /// - `seed`: Seed id
    rand-id: func(def: borrow<synth-def>, ugen-rate: rate, seed: ugen-input) -> ugen-input;

    /// When the trigger signal changes from nonpositive to positive, the
    /// synth's random generator seed is reset to the given value. All synths
    /// that use the same random number generator reproduce the same sequence of
    /// numbers again.
    /// 
    /// Args:
    /// - `trig`: Trigger signal
    /// - `seed`: Seed value
    rand-seed: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, seed: ugen-input) -> ugen-input;

    /// record a stream of values into a buffer. If recLevel is 1.0 and preLevel
    /// is 0.0 then the new input overwrites the old data. If they are both 1.0
    /// then the new data is added to the existing data. (Any other settings are
    /// also valid.) Note that the number of channels must be fixed for the
    /// defsynth, it cannot vary depending on which buffer you use.
    /// 
    /// Args:
    /// - `input-array`: an Array of input channels
    /// - `bufnum`: the index of the buffer to use
    /// - `offset`: an offset into the buffer in frames,
    /// - `rec-level`: value to multiply by input before mixing with existing
    /// data.
    /// - `pre-level`: value to multiply to existing data in buffer before
    /// mixing with input
    /// - `run`: If zero, then recording stops, otherwise recording proceeds.
    /// - `loop`: If zero then don't loop, otherwise do. This is modulate-able.
    /// - `trigger`: a trigger causes a jump to the offset position in the
    /// Buffer. A trigger occurs when a signal changes from <= 0 to > 0.
    /// - `action`: an integer representing an action to be executed when the
    /// buffer is finished playing. This can be used to free the enclosing
    /// synth. Action is only evaluated if loop is 0
    record-buf: func(def: borrow<synth-def>, ugen-rate: rate, input-array: list<ugen-input>, bufnum: ugen-input, offset: ugen-input, rec-level: ugen-input, pre-level: ugen-input, run: ugen-input, loop: ugen-input, trigger: ugen-input, action: ugen-input) -> ugen-input;

    /// Send signal to a bus, overwriting previous contents.
    /// 
    /// Out adds its output to a given bus, making it available to all nodes
    /// later in the node tree (See Synth and Order-of-execution for more
    /// information). ReplaceOut overwrites those contents. This can make it
    /// useful for processing.
    /// 
    /// Args:
    /// - `bus`: the index of the buss to write to. The lowest index numbers are
    /// written to the audio hardware.
    /// - `channels-array`: a list of signals or single output to write out. You
    /// cannot change the size of this once a synth has been defined.
    replace-out: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// A Note on Constant-Gain Digital Resonators,\" Computer Music Journal,
    /// vol 18, no. 4, pp. 8-10, Winter 1994.\" Computer Music Journal, vol 18,
    /// no. 4, pp. 8-10, Winter 1994.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: resonant frequency in Hertz
    /// - `bwr`: bandwidth ratio (reciprocal of Q). rq = bandwidth / centerFreq
    resonz: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, bwr: ugen-input) -> ugen-input;

    /// Ringz is the same as Resonz, except that instead of a resonance
    /// parameter, the bandwidth is specified in a 60dB ring decay time. One
    /// Ringz is equivalent to one component of the klank ugen
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: resonant frequency in Hertz
    /// - `decay-time`: the 60 dB decay time of the filter
    ringz: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, decay-time: ugen-input) -> ugen-input;

    /// Rotate2 can be used for rotating an ambisonic B-format sound field
    /// around an axis. Rotate2 does an equal power rotation so it also works
    /// well on stereo sounds. It takes two audio inputs (x, y) and an angle
    /// control (pos). It outputs two channels (x, y). It computes this: xout =
    /// cos(angle) * xin + sin(angle) * yin; yout = cos(angle) * yin -
    /// sin(angle) * xin; where angle = pos * pi, so that -1 becomes -pi and +1
    /// becomes +pi. This allows you to use an LFSaw to do continuous rotation
    /// around a circle.
    /// 
    /// Args:
    /// - `x`: input signal
    /// - `y`: input signal
    /// - `pos`: angle to rotate around the circle from -1 to +1. -1 is 180
    /// degrees, -0.5 is left, 0 is forward, +0.5 is right, +1 is behind.
    rotate2: func(def: borrow<synth-def>, ugen-rate: rate, x: ugen-input, y: ugen-input, pos: ugen-input) -> ugen-input;

    /// Track maximum level
    /// 
    /// Outputs the maximum value received at the input. When triggered, the
    /// maximum output value is reset to the current value.
    /// 
    /// Args:
    /// - `%in`: Input signal.
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    running-max: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig: ugen-input) -> ugen-input;

    /// Track minimum level
    /// 
    /// Outputs the minimum value received at the input. When triggered, the
    /// minimum output value is reset to the current value.
    /// 
    /// Args:
    /// - `%in`: Input signal.
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    running-min: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, trig: ugen-input) -> ugen-input;

    /// A running sum over a user specified number of samples, useful for
    /// running RMS power windowing.
    /// 
    /// Args:
    /// - `%in`: Input signal
    /// - `numsamp`: How many samples to take the running sum over
    /// (initialisation time only, not modulatable.
    running-sum: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, numsamp: ugen-input) -> ugen-input;

    /// second order filter section (biquad). Formula is equivalent to: out(i) =
    /// (a0 * in(i)) + (a1 * in(i-1)) + (a2 * in(i-2)) + (b1 * out(i-1)) + (b2 *
    /// out(i-2))
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `a0`: 1st coefficient
    /// - `a1`: 2nd coefficient
    /// - `a2`: 3rd coefficient
    /// - `b1`: 4th coefficient
    /// - `b2`: 5th coefficient
    sos: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, a0: ugen-input, a1: ugen-input, a2: ugen-input, b1: ugen-input, b2: ugen-input) -> ugen-input;

    /// returns the current sample duration of the server in seconds
    sample-dur: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// returns the current sample rate
    sample-rate: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// band limited sawtooth wave generator
    /// 
    /// The sawtooth wave produces even and odd harmonics in series and
    /// therefore produces a bright sound that is an excellent starting point
    /// for brassy, raspy sounds. It's also suitable for creating the gritty,
    /// bright sounds needed for leads and raspy basses. Due to its harmonic
    /// richness it's extremely suitable for use with sounds that will be filter
    /// swept.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz (control rate).
    saw: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input) -> ugen-input;

    /// Schmidt trigger
    /// 
    /// Outout one when signal greater than high, and zero when lower than low.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lo`: low threshold
    /// - `hi`: high threshold
    schmidt: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    scope-out: func(def: borrow<synth-def>, ugen-rate: rate, input-array: list<ugen-input>, bufnum: ugen-input) -> ugen-input;

    scope-out2: func(def: borrow<synth-def>, ugen-rate: rate, input-array: list<ugen-input>, scope-num: ugen-input, max-frames: ugen-input, scope-frames: ugen-input) -> ugen-input;

    /// select the output signal from an array of inputs
    /// 
    /// Args:
    /// - `which`: Index of array to select
    /// - `channels-array`: List of ugens to choose from
    select: func(def: borrow<synth-def>, ugen-rate: rate, which: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// Send information via OSC to Overtone
    /// 
    /// Send an array of values from the server via an message. The OSC message
    /// is formed with cmd-name as the path, followed by two compulsary args:
    /// node-id (the id of the node that sent the message) and reply-id (the
    /// value specified in the params). These args are then followed by the list
    /// of values specified in the params. For example, if the ugen is used as
    /// follows: (send-reply tr \"/foobar\" [1 2 3] 42) When the trig tr
    /// triggers, Overtone will receive an event that looks like the following
    /// (where 32 represents the node-id of the synth that sent the message):
    /// {:path \"/foobar\
    /// 
    /// Args:
    /// - `trig`: Input trigger signal
    /// - `cmd-name`: A string or symbol, as a message name.
    /// - `values`: Array of ugens, or valid ugen inputs
    /// - `reply-id`: Integer id (similar to that used by send-trig)
    send-reply: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, cmd-name: ugen-input, values: ugen-input, reply-id: ugen-input) -> ugen-input;

    /// Send a /tr OSC message to Overtone
    /// 
    /// On receiving a trigger sends a :trigger event with id and value. This
    /// command is the mechanism that synths can use to trigger events in
    /// clients. The trigger message sent back to the client is this: int - node
    /// ID int - trigger ID float - trigger value This is then presented as an
    /// event on the event-stream which is a map containing the key :path with
    /// the string \"/tr\" and the key :args containing a sequence of the values
    /// in the above order. i.e. {:path /tr, :args (34 3 123.0)} See on-trigger,
    /// on-latest-trigger and on-sync-trigger for registering handlers for
    /// trigger events.
    /// 
    /// Args:
    /// - `%in`: input trigger signal
    /// - `id`: an integer that will be passed with the trigger message. This is
    /// useful if you have more than one send-trig in a synth design. Consider
    /// using trig-id to genearate a unique id.
    /// - `value`: A ugen or float that will be polled at the time of trigger,
    /// and its value passed with the trigger message
    send-trig: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, id: ugen-input, value: ugen-input) -> ugen-input;

    set-buf: func(def: borrow<synth-def>, ugen-rate: rate, buf: ugen-input, values: ugen-input, offset: ugen-input) -> ugen-input;

    /// Set-reset flip flop
    /// 
    /// When a trigger is received the output is set to 1.0 Subsequent triggers
    /// have no effect When a trigger is received in the reset input, the output
    /// is set back to 0.0 One use of this is to have some precipitating event
    /// cause something to happen until you reset it.
    /// 
    /// Args:
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `reset`: Resets the counter to zero when triggered.
    set-reset-ff: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, reset: ugen-input) -> ugen-input;

    /// performs waveshaping on the input signal by indexing into a table
    shaper: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input) -> ugen-input;

    /// read from a shared control bus (internal dsp only)
    /// 
    /// Reads from a control bus shared between the internal server and the SC
    /// client. Control rate only. Writing to a shared control bus from the
    /// client is synchronous. When not using the internal server use node
    /// arguments or the set method of Bus (or /c_set in messaging style).
    /// 
    /// Args:
    /// - `bus`: the index of the shared control bus to read from
    /// - `num-channels`: the number of channels (i.e. adjacent buses) to read
    /// in. The default is 1. You cannot modulate this number by assigning it to
    /// an argument in a SynthDef.
    shared-in: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, num-channels: u32) -> ugen-input;

    /// Reads from a control bus shared between the internal server and the SC
    /// client. Control rate only. Reading from a shared control bus on the
    /// client is synchronous.
    /// 
    /// Args:
    /// - `bus`: the index of the shared control bus to read from
    /// - `channels-array`: an Array of channels or single output to write out.
    /// You cannot change the size of this once a SynthDef has been built.
    shared-out: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// Continuously outputs 0
    /// 
    /// Args:
    /// - `num-channels`: Number of channels of silence.
    silent: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32) -> ugen-input;

    /// Sine table lookup oscillator
    /// 
    /// Outputs a sine wave with values oscillating between -1 and 1 similar to
    /// osc except that the table has already been fixed as a sine table of 8192
    /// entries. Sine waves are often used for creating sub-basses or are mixed
    /// with other waveforms to add extra body or bottom end to a sound. They
    /// contain no harmonics and consist entirely of the fundamental frequency.
    /// This means that they're not suitable for subtractive synthesis i.e.
    /// passing through filters such as a hpf or lpf. However, they are useful
    /// for additive synthesis i.e. adding multiple sine waves together at
    /// different frequencies, amplitudes and phase to create new timbres.
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `phase`: Phase offset or modulator in radians
    sin-osc: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, phase: ugen-input) -> ugen-input;

    /// Sine oscillator with phase modulation feedback
    /// 
    /// Different feedback values results in a modulation between a sine wave
    /// and a sawtooth like wave. Overmodulation causes chaotic oscillation.
    /// 
    /// Args:
    /// - `freq`: Frequency of oscillator
    /// - `feedback`: amplitude of phase feedback in radians
    sin-osc-fb: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, feedback: ugen-input) -> ugen-input;

    /// Smooth the curve by limiting the slope of the input signal to up and dn
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `up`: maximum upward slope
    /// - `dn`: maximum downward slope
    slew: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, up: ugen-input, dn: ugen-input) -> ugen-input;

    /// Measures the rate of change per second of a signal. Formula implemented
    /// is: out[i] = (in[i] - in[i-1]) * sampling_rate
    /// 
    /// Args:
    /// - `%in`: input signal to measure
    slope: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// Given an FFT chain, this measures the spectral centroid, which is the
    /// weighted mean frequency, or the centre of mass of the spectrum. (DC is
    /// ignored.) This can be a useful indicator of the perceptual brightness of
    /// a signal.
    /// 
    /// Args:
    /// - `chain`: An FFT chain
    spec-centroid: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input) -> ugen-input;

    /// Given an FFT chain this calculates the Spectral Flatness measure,
    /// defined as a power spectrum's geometric mean divided by its arithmetic
    /// mean. This gives a measure which ranges from approx 0 for a pure
    /// sinusoid, to approx 1 for white noise. The measure is calculated
    /// linearly. For some applications you may wish to convert the value to a
    /// decibel scale - an example of such conversion is shown below.
    /// 
    /// Args:
    /// - `chain`: An FFT chain
    spec-flatness: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input) -> ugen-input;

    /// Find a percentile of FFT magnitude spectrum" , :rates #{:kr} :doc "Given
    /// an FFT chain this calculates the cumulative distribution of the
    /// frequency spectrum, and outputs the frequency value which corresponds to
    /// the desired percentile. For example, to find the frequency at which 90%
    /// of the spectral energy lies below that frequency, you want the
    /// 90-percentile, which means the value of fraction should be 0.9. The
    /// 90-percentile or 95-percentile is often used as a measure of spectral
    /// roll-off. The optional third argument interpolate specifies whether
    /// interpolation should be used to try and make the percentile frequency
    /// estimate more accurate, at the cost of a little higher CPU usage. Set it
    /// to 1 to enable this.
    /// 
    /// Given an FFT chain this calculates the cumulative distribution of the
    /// frequency spectrum, and outputs the frequency value which corresponds to
    /// the desired percentile. For example, to find the frequency at which 90%
    /// of the spectral energy lies below that frequency, you want the
    /// 90-percentile, which means the value of fraction should be 0.9. The
    /// 90-percentile or 95-percentile is often used as a measure of spectral
    /// roll-off. The optional third argument interpolate specifies whether
    /// interpolation should be used to try and make the percentile frequency
    /// estimate more accurate, at the cost of a little higher CPU usage. Set it
    /// to 1 to enable this.
    /// 
    /// Args:
    /// - `chain`: An FFT chain
    /// - `fraction`: percentage of the spectral energy you which to find the
    /// frequency for
    /// - `interpolate`: Interpolation toggle - 0 off 1 on.
    spec-pcile: func(def: borrow<synth-def>, ugen-rate: rate, chain: ugen-input, fraction: ugen-input, interpolate: ugen-input) -> ugen-input;

    /// Physical model of resonating spring
    /// 
    /// Args:
    /// - `%in`: Modulated input force
    /// - `spring`: Spring constant (incl. mass)
    /// - `damp`: Damping
    spring: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, spring: ugen-input, damp: ugen-input) -> ugen-input;

    /// linear-interpolating standard map chaotic generator. The standard map is
    /// an area preserving map of a cylinder discovered by the plasma physicist
    /// Boris Chirikov.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `k`: perturbation amount
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    standard-l: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, k: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// standard map chaotic generator. The standard map is an area preserving
    /// map of a cylinder discovered by the plasma physicist Boris Chirikov.
    /// 
    /// Args:
    /// - `freq`: iteration frequency in Hertz
    /// - `k`: perturbation amount
    /// - `xi`: initial value of x
    /// - `yi`: initial value of y
    standard-n: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, k: ugen-input, xi: ugen-input, yi: ugen-input) -> ugen-input;

    /// Pulse counter
    /// 
    /// Triggers increment a counter which is output as a signal. The counter
    /// loops around from max to min by step increments
    /// 
    /// Args:
    /// - `trig`: Trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `reset`: Resets the counter to resetval when triggered.
    /// - `min`: minimum value of the counter.
    /// - `max`: maximum value of the counter.
    /// - `step`: step value each trigger. May be negative.
    /// - `resetval`: value to which the counter is reset when it receives a
    /// reset trigger.
    stepper: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, reset: ugen-input, min: ugen-input, max: ugen-input, step: ugen-input, resetval: ugen-input) -> ugen-input;

    /// Strict convolution with fixed kernel which can be updated using a
    /// trigger signal. There is a linear crossfade between the buffers upon
    /// change. Like convolution2L, but convolves with two buffers and outputs a
    /// stereo signal. This saves one FFT transformation per period, as compared
    /// to using two copies of convolution2L. Useful applications could include
    /// stereo reverberation or HRTF convolution. See Steven W Smith, The
    /// Scientist and Engineer's Guide to Digital Signal Processing: chapter 18:
    /// http://www.dspguide.com/ch18.htm
    /// 
    /// Args:
    /// - `%in`: processing target
    /// - `kernel-l`: buffer index for the fixed kernel of the left channel, may
    /// be modulated in combination with the trigger
    /// - `kernel-r`: buffer index for the fixed kernel of the right channel,
    /// may be modulated in combination with the trigger
    /// - `trigger`: update the kernel on a change from <= 0 to > 0
    /// - `framesize`: size of FFT frame, must be a power of two. Convolution
    /// uses twice this number internally, maximum value you can give this
    /// argument is 2^16=65536. Note that it gets progressively more expensive
    /// to run for higher powers! 512, 1024, 2048, 4096 standard.
    /// - `crossfade`: The number of periods over which a crossfade is made.
    /// This must be an integer.
    stereo-convolution2-l: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, kernel-l: ugen-input, kernel-r: ugen-input, trigger: ugen-input, framesize: ugen-input, crossfade: ugen-input) -> ugen-input;

    /// offset from synth start within one sample
    subsample-offset: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// Triggered linear ramp
    /// 
    /// outputs a linear increasing signal by rate/second when trig input
    /// crosses from non-positive to positive
    /// 
    /// Args:
    /// - `trig`: trigger input
    /// - `rate`: rate in seconds
    sweep: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, rate: ugen-input) -> ugen-input;

    /// hard sync sawtooth wave oscillator
    /// 
    /// A sawtooth wave that is hard synched to a fundamental pitch. This
    /// produces an effect similar to moving formants or pulse width modulation.
    /// The sawtooth oscillator has its phase reset when the sync oscillator
    /// completes a cycle. This is not a band limited waveform, so it may alias.
    /// 
    /// Args:
    /// - `sync-freq`: Frequency of the fundamental.
    /// - `saw-freq`: Frequency of the slave synched sawtooth wave. saw-freq
    /// should always be greater than sync-freq.
    sync-saw: func(def: borrow<synth-def>, ugen-rate: rate, sync-freq: ugen-input, saw-freq: ugen-input) -> ugen-input;

    /// control rate trigger to audio rate trigger converter (maximally one per
    /// control period).
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `offset`: sample offset within control period
    t2-a: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, offset: ugen-input) -> ugen-input;

    /// audio rate trigger to control rate trigger converter. Uses the maxiumum
    /// trigger in the input during each control period.
    /// 
    /// Args:
    /// - `%in`: input signal
    t2-k: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

    /// models the impacts of a bouncing object that is reflected by a vibrating
    /// surface
    /// 
    /// Args:
    /// - `%in`: modulated surface level
    /// - `g`: gravity
    /// - `damp`: damping on impact
    /// - `friction`: proximity from which on attraction to surface starts
    t-ball: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, g: ugen-input, damp: ugen-input, friction: ugen-input) -> ugen-input;

    /// Trigger delay
    /// 
    /// Delays an input trigger by dur, ignoring other triggers in the meantime
    /// 
    /// Args:
    /// - `trig`: input trigger signal.
    /// - `dur`: delay time in seconds.
    t-delay: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, dur: ugen-input) -> ugen-input;

    /// This ugen has been internalised for scserver compatibility. Please use
    /// the tduty cgen instead.
    /// 
    /// Args:
    /// - `action`: Default: NO-ACTION
    t-duty: func(def: borrow<synth-def>, ugen-rate: rate, dur: ugen-input, reset: ugen-input, action: ugen-input, level: ugen-input, gap-first: ugen-input) -> ugen-input;

    /// Generates a random float value in exponential distribution from lo to hi
    /// each time the trig signal changes from nonpositive to positive values lo
    /// and hi must both have the same sign and be non-zero.
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated float
    /// - `hi`: Maximum value of generated float
    /// - `trig`: Trigger signal
    t-exp-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input, trig: ugen-input) -> ugen-input;

    /// sample playback from a buffer with fine control for doing granular
    /// synthesis. Triggers generate grains from a single channel (mono) buffer.
    /// Each grain has a Hann envelope (sin^2(x) for x from 0 to pi) and is
    /// panned between two channels of multiple outputs.
    /// 
    /// Args:
    /// - `num-channels`: number of output channels
    /// - `trigger`: at each trigger, the following arguments are sampled and
    /// used as the arguments of a new grain. A trigger occurs when a signal
    /// changes from <= 0 to > 0. If the trigger is audio rate then the grains
    /// will start with sample accuracy.
    /// - `bufnum`: the index of the buffer to use. It must be a one channel
    /// (mono) buffer.
    /// - `rate`: 1.0 is normal, 2.0 is one octave up, 0.5 is one octave down
    /// -1.0 is backwards normal rate. Unlike PlayBuf, the rate is multiplied by
    /// BufRate, so you needn't do that yourself.
    /// - `center-pos`: the position in the buffer in seconds at which the grain
    /// envelope will reach maximum amplitude.
    /// - `dur`: duration of the grain in seconds
    /// - `pan`: a value from -1 to 1. Determines where to pan the output in the
    /// same manner as PanAz.
    /// - `amp`: amplitude of the grain.
    /// - `interp`: 1,2,or 4. Determines whether the grain uses (1) no
    /// interpolation, (2) linear interpolation, or (4) cubic interpolation.
    t-grains: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, trigger: ugen-input, bufnum: ugen-input, rate: ugen-input, center-pos: ugen-input, dur: ugen-input, pan: ugen-input, amp: ugen-input, interp: ugen-input) -> ugen-input;

    /// Generates a random integer value in uniform distribution from lo to hi
    /// each time the trig signal changes from nonpositive to positive values
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated integer
    /// - `hi`: Maximum value of generated integer
    /// - `trig`: Trigger signal
    ti-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input, trig: ugen-input) -> ugen-input;

    /// Generates a random float value in uniform distribution from lo to hi
    /// each time the trig signal changes from nonpositive to positive values
    /// 
    /// Args:
    /// - `lo`: Minimum value of generated float
    /// - `hi`: Maximum value of generated float
    /// - `trig`: Trigger signal
    t-rand: func(def: borrow<synth-def>, ugen-rate: rate, lo: ugen-input, hi: ugen-input, trig: ugen-input) -> ugen-input;

    /// Triggered window
    /// 
    /// When triggered, returns a random index value based on array as a list of
    /// probabilities. By default the list of probabilities should sum to 1.0,
    /// when the normalize flag is set to 1, the values get normalized by the
    /// ugen (less efficient).
    /// 
    /// Args:
    /// - `trig`: Trigger - can be any signal. A trigger happens when the signal
    /// changes from non-positive to positive.
    /// - `channels-array`: list of probabilities
    /// - `normalize`: normalise flag - 0 off, 1 on
    t-windex: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, channels-array: list<ugen-input>, normalize: ugen-input) -> ugen-input;

    /// Trigger timer
    /// 
    /// Outputs time since last trigger
    /// 
    /// Args:
    /// - `trig`: trigger input
    timer: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input) -> ugen-input;

    /// Toggle flip flop
    /// 
    /// Flip-flops between zero and one each trigger
    /// 
    /// Args:
    /// - `trig`: trigger input
    toggle-ff: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input) -> ugen-input;

    trapezoid: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, a: ugen-input, b: ugen-input, c: ugen-input, d: ugen-input) -> ugen-input;

    /// Timed trigger
    /// 
    /// When a nonpositive to positive transition occurs at the input, Trig
    /// outputs the level of the triggering input for the specified duration,
    /// otherwise it outputs zero.
    /// 
    /// Args:
    /// - `trig`: trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `dur`: duration of the trigger output in seconds.
    trig: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, dur: ugen-input) -> ugen-input;

    /// Timed trigger
    /// 
    /// Outputs one for dur seconds whenever the input goes from negative to
    /// positive, otherwise outputs 0.
    /// 
    /// Args:
    /// - `trig`: trigger. Trigger can be any signal. A trigger happens when the
    /// signal changes from non-positive to positive.
    /// - `dur`: duration of the trigger output in seconds.
    trig1: func(def: borrow<synth-def>, ugen-rate: rate, trig: ugen-input, dur: ugen-input) -> ugen-input;

    /// a two pole filter. This provides lower level access to setting of pole
    /// location. For general purposes Resonz is better.
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: frequency of pole angle
    /// - `radius`: radius of pole. Should be between 0 and +1
    two-pole: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, radius: ugen-input) -> ugen-input;

    /// a two zero filter
    /// 
    /// Args:
    /// - `%in`: input signal to be processed
    /// - `freq`: frequency of zero angle
    /// - `radius`: radius of zero
    two-zero: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, freq: ugen-input, radius: ugen-input) -> ugen-input;

    /// stream in audio from a file (with variable rate)
    /// 
    /// Continuously play a longer soundfile from disk. This requires a buffer
    /// to be preloaded with one buffer size of sound.
    /// 
    /// Args:
    /// - `num-channels`: Number of channels in the audio
    /// - `bufnum`: id of buffer
    /// - `rate`: controls the rate of playback. Values below 4 are probably
    /// fine, but the higher the value, the more disk activity there is, and the
    /// more likelihood there will be a problem.
    /// - `loop`: Soundfile will loop if 1 otherwise not.
    /// - `send-id`: send an osc message with this id and the file position each
    /// time the buffer is reloaded: ['/diskin', nodeID, sendID, frame]
    v-disk-in: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, bufnum: ugen-input, rate: ugen-input, loop: ugen-input, send-id: ugen-input) -> ugen-input;

    /// A wavetable lookup oscillator which can be swept smoothly across
    /// wavetables. All the wavetables must be allocated to the same size.
    /// Fractional values of table will interpolate between two adjacent tables.
    /// This oscillator requires at least two buffers to be filled with a
    /// wavetable format signal. This preprocesses the Signal into a form which
    /// can be used efficiently by the Oscillator. The buffer size must be a
    /// power of 2.
    /// 
    /// Args:
    /// - `bufpos`: Buffer index. Can be swept continuously among adjacent
    /// wavetable buffers of the same size.
    /// - `freq`: Frequency in Hertz
    /// - `phase`: Phase offset of modulator in radians
    v-osc: func(def: borrow<synth-def>, ugen-rate: rate, bufpos: ugen-input, freq: ugen-input, phase: ugen-input) -> ugen-input;

    /// Three variable wavetable oscillators. A wavetable lookup oscillator
    /// which can be swept smoothly across wavetables. All the wavetables must
    /// be allocated to the same size. Fractional values of table will
    /// interpolate between two adjacent tables. This unit generator contains
    /// three oscillators at different frequencies, mixed together. This
    /// oscillator requires at least two buffers to be filled with a wavetable
    /// format signal. This preprocesses the Signal into a form which can be
    /// used efficiently by the Oscillator. The buffer size must be a power of
    /// 2.
    /// 
    /// Args:
    /// - `bufpos`: Buffer index. Can be swept continuously among adjacent
    /// wavetable buffers of the same size.
    /// - `freq1`: Frequency in Hertz of first oscillator
    /// - `freq2`: Frequency in Hertz of second oscillator
    /// - `freq3`: Frequency in Hertz of third oscillator
    v-osc3: func(def: borrow<synth-def>, ugen-rate: rate, bufpos: ugen-input, freq1: ugen-input, freq2: ugen-input, freq3: ugen-input) -> ugen-input;

    /// a variable duty cycle saw wave oscillator
    /// 
    /// Args:
    /// - `freq`: Frequency in Hertz
    /// - `iphase`: Initial phase offset in cycles ( 0..1 )
    /// - `width`: Duty cycle from zero to one. (0 = downward sawtooth, 0.5 =
    /// triangle, 1 = upward sawtooth)
    var-saw: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, iphase: ugen-input, width: ugen-input) -> ugen-input;

    /// Models a slow frequency modulation.
    /// 
    /// Vibrato is a slow frequency modulation. Consider the systematic
    /// deviation in pitch of a singer around a fundamental frequency, or a
    /// violinist whose finger wobbles in position on the fingerboard, slightly
    /// tightening and loosening the string to add shimmer to the pitch. There
    /// is often also a delay before vibrato is established on a note. This UGen
    /// models these processes; by setting more extreme settings, you can get
    /// back to the timbres of FM synthesis. You can also add in some noise to
    /// the vibrato rate and vibrato size (modulation depth) to make for a more
    /// realistic motor pattern. The vibrato output is a waveform based on a
    /// squared envelope shape with four stages marking out 0.0 to 1.0, 1.0 to
    /// 0.0, 0.0 to -1.0, and -1.0 back to 0.0. Vibrato rate determines how
    /// quickly you move through these stages.
    /// 
    /// Args:
    /// - `freq`: Fundamental frequency in Hertz. If the Vibrato UGen is running
    /// at audio rate, this must not be a constant, but an actual audio rate
    /// UGen
    /// - `rate`: Vibrato rate, speed of wobble in Hertz. Note that if this is
    /// set to a low value (and definitely with 0.0), you may never get vibrato
    /// back, since the rate input is only checked at the end of a cycle.
    /// - `depth`: Size of vibrato frequency deviation around the fundamental,
    /// as a proportion of the fundamental. 0.02 = 2% of the fundamental.
    /// - `delay`: Delay before vibrato is established in seconds (a singer
    /// tends to attack a note and then stabilise with vibrato, for instance).
    /// - `onset`: Transition time in seconds from no vibrato to full vibrato
    /// after the initial delay time.
    /// - `rate-variation`: Noise on the rate, expressed as a proportion of the
    /// rate; can change once per cycle of vibrato.
    /// - `depth-variation`: Noise on the depth of modulation, expressed as a
    /// proportion of the depth; can change once per cycle of vibrato. The noise
    /// affects independently the up and the down part of vibrato shape within a
    /// cycle.
    /// - `iphase`: Initial phase of vibrato modulation, allowing starting above
    /// or below the fundamental rather than on it.
    vibrato: func(def: borrow<synth-def>, ugen-rate: rate, freq: ugen-input, rate: ugen-input, depth: ugen-input, delay: ugen-input, onset: ugen-input, rate-variation: ugen-input, depth-variation: ugen-input, iphase: ugen-input) -> ugen-input;

    /// A granular time stretcher and pitchshifter. Inspired by Chad Kirby's
    /// SuperCollider2 Warp1 class, which was inspired by Richard Karpen's
    /// sndwarp for CSound.
    /// 
    /// Args:
    /// - `num-channels`: the number of channels in the soundfile used in
    /// bufnum.
    /// - `bufnum`: the buffer number of a mono soundfile.
    /// - `pointer`: the position in the buffer. The value should be between 0
    /// and 1, with 0 being the begining of the buffer, and 1 the end.
    /// - `freq-scale`: the amount of frequency shift. 1.0 is normal, 0.5 is one
    /// octave down, 2.0 is one octave up. Negative values play the soundfile
    /// backwards.
    /// - `window-size`: the size of each grain window.
    /// - `envbufnum`: the buffer number containing a singal to use for the
    /// grain envelope. -1 uses a built-in Hanning envelope.
    /// - `overlaps`: the number of overlaping windows.
    /// - `window-rand-ratio`: the amount of randomness to the windowing
    /// function. Must be between 0 (no randomness) to 1.0 (probably to random
    /// actually)
    /// - `interp`: the interpolation method used for pitchshifting grains. 1 =
    /// no interpolation. 2 = linear. 4 = cubic interpolation (more
    /// computationally intensive).
    warp1: func(def: borrow<synth-def>, ugen-rate: rate, num-channels: u32, bufnum: ugen-input, pointer: ugen-input, freq-scale: ugen-input, window-size: ugen-input, envbufnum: ugen-input, overlaps: ugen-input, window-rand-ratio: ugen-input, interp: ugen-input) -> ugen-input;

    /// Noise whose spectrum has equal power at all frequencies.
    /// 
    /// Noise that contains equal amounts of energy at every frequency -
    /// comparable to radio static. Useful for generating percussive sounds such
    /// as snares and hand claps. Also useful for simulating wind or sea
    /// effects, for producing breath effects in wind instrument timbres or for
    /// producing the typical trance leads.
    white-noise: func(def: borrow<synth-def>, ugen-rate: rate) -> ugen-input;

    /// Wrap a signal outside given thresholds.
    /// 
    /// Wraps input wave to the low and high thresholds. This differs from the
    /// ugen wrap2 in that it allows one to set both low and high thresholds.
    /// 
    /// Args:
    /// - `%in`: input signal
    /// - `lo`: low threshold
    /// - `hi`: high threshold
    wrap: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input, lo: ugen-input, hi: ugen-input) -> ugen-input;

    /// the input signal value is truncated to an integer value and used as an
    /// index into the table (out of range index values are wrapped)
    wrap-index: func(def: borrow<synth-def>, ugen-rate: rate, bufnum: ugen-input, %in: ugen-input) -> ugen-input;

    /// Equal power two channel cross fade
    /// 
    /// Args:
    /// - `in-a`: input signal A
    /// - `in-b`: input signal B
    /// - `pan`: Pan between the two input signals with -1 being inA only and 1
    /// being inB only with values between being a mix of the two.
    /// - `level`: Output level - 0 being silent and 1 being original volume
    x-fade2: func(def: borrow<synth-def>, ugen-rate: rate, in-a: ugen-input, in-b: ugen-input, pan: ugen-input, level: ugen-input) -> ugen-input;

    /// Exponential line generator.
    /// 
    /// Generates an exponential curve from the start value to the end value.
    /// Both the start and end values must be non-zero and have the same sign.
    /// 
    /// Args:
    /// - `start`: Starting value
    /// - `end`: Ending value
    /// - `dur`: Duration in seconds
    /// - `action`: A done action to be evaluated when the line is completed.
    /// Default: NO-ACTION
    x-line: func(def: borrow<synth-def>, ugen-rate: rate, start: ugen-input, end: ugen-input, dur: ugen-input, action: ugen-input) -> ugen-input;

    /// write signal to a bus, crossfading with the existing content
    /// 
    /// xfade is a level for the crossfade between what is on the bus and what
    /// you are sending. The algorithm is equivalent to this: bus_signal =
    /// (input_signal * xfade) + (bus_signal * (1 - xfade));
    /// 
    /// Args:
    /// - `bus`: the index, or array of indexes, of buses to write to. The
    /// lowest index numbers are written to the audio hardware.
    /// - `xfade`: crossfade level.
    /// - `channels-array`: an Array of channels or single output to write out.
    /// You cannot change the size of this once a SynthDef has been built.
    x-out: func(def: borrow<synth-def>, ugen-rate: rate, bus: ugen-input, xfade: ugen-input, channels-array: list<ugen-input>) -> ugen-input;

    /// Zero crossing frequency follower
    /// 
    /// Outputs a frequency based upon the distance between interceptions of the
    /// X axis. The X intercepts are determined via linear interpolation so this
    /// gives better than just integer wavelength resolution. This is a very
    /// crude pitch follower, but can be useful in some situations.
    /// 
    /// Args:
    /// - `%in`: input signal
    zero-crossing: func(def: borrow<synth-def>, ugen-rate: rate, %in: ugen-input) -> ugen-input;

}

/// Canonical world for embedders of the scsynthdef compiler.
world scsynthdef {
    export core;
    export ugens;
}
