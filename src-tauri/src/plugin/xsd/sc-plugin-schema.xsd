<xs:schema
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    targetNamespace="http://www.w3.org/1999/xhtml"
    xmlns="http://www.w3.org/1999/xhtml"
    elementFormDefault="qualified">

  <xs:attributeGroup name="commonAttrs">
    <xs:attribute name="id" type="xs:string" use="optional"/>
    <xs:attribute name="class" type="xs:string" use="optional"/>
    <xs:attribute name="title" type="xs:string" use="optional"/>
    <xs:attribute name="style" type="xs:string" use="optional"/>
  </xs:attributeGroup>


  <!-- ==================== Global element declarations ==================== -->

  <!-- HTML elements -->
  <xs:element name="div" type="blockType"/>
  <xs:element name="p" type="inlineType"/>
  <xs:element name="label" type="blockType"/>
  <xs:element name="span" type="inlineType"/>
  <xs:element name="strong" type="inlineType"/>
  <xs:element name="em" type="inlineType"/>
  <xs:element name="h1" type="inlineType"/>
  <xs:element name="h2" type="inlineType"/>
  <xs:element name="h3" type="inlineType"/>
  <xs:element name="h4" type="inlineType"/>
  <xs:element name="h5" type="inlineType"/>
  <xs:element name="h6" type="inlineType"/>
  <xs:element name="ul" type="listType"/>
  <xs:element name="ol" type="listType"/>
  <xs:element name="li" type="blockType"/>
  <xs:element name="hr"/>
  <xs:element name="br"/>

  <!-- sc-* elements -->
  <xs:element name="sc-display" type="scDisplayType"/>
  <xs:element name="sc-if" type="scIfType"/>
  <xs:element name="sc-range" type="scRangeType"/>
  <xs:element name="sc-checkbox" type="scCheckboxType"/>
  <xs:element name="sc-group" type="scGroupType"/>
  <xs:element name="sc-synth" type="scSynthType"/>
  <xs:element name="sc-synthdef" type="scSynthDefType"/>
  <xs:element name="sc-ugen" type="scUGenType"/>
  <xs:element name="sc-run" type="scRunType"/>
  <xs:element name="sc-control" type="scControlType"/>
  <xs:element name="sc-radio-group" type="scRadioGroupType"/>
  <xs:element name="sc-radio" type="scRadioType"/>
  <xs:element name="sc-var" type="scVarType"/>
  <xs:element name="sc-buffer" type="scBufferType"/>
  <xs:element name="sc-record" type="scRecordType"/>
  <xs:element name="sc-select" type="scSelectType"/>
  <xs:element name="sc-option" type="scOptionType"/>

  <!-- ==================== Content model groups ==================== -->

  <xs:group name="htmlElements">
    <xs:choice>
      <xs:element ref="div"/>
      <xs:element ref="p"/>
      <xs:element ref="label"/>
      <xs:element ref="ul"/>
      <xs:element ref="ol"/>
      <xs:element ref="h1"/>
      <xs:element ref="h2"/>
      <xs:element ref="h3"/>
      <xs:element ref="h4"/>
      <xs:element ref="h5"/>
      <xs:element ref="h6"/>
      <xs:element ref="hr"/>
      <xs:element ref="span"/>
      <xs:element ref="br"/>
    </xs:choice>
  </xs:group>

  <xs:group name="scControls">
    <xs:choice>
      <xs:element ref="sc-display"/>
      <xs:element ref="sc-if"/>
      <xs:element ref="sc-range"/>
      <xs:element ref="sc-checkbox"/>
      <xs:element ref="sc-run"/>
      <xs:element ref="sc-select"/>
      <xs:element ref="sc-radio-group"/>
      <xs:element ref="sc-record"/>
    </xs:choice>
  </xs:group>

  <xs:group name="blockContent">
    <xs:choice>
      <xs:group ref="htmlElements"/>
      <xs:group ref="scControls"/>
      <xs:element ref="sc-control"/>
      <xs:element ref="sc-var"/>
      <xs:element ref="sc-group"/>
      <xs:element ref="sc-synth"/>
      <xs:element ref="sc-synthdef"/>
      <xs:element ref="sc-buffer"/>
    </xs:choice>
  </xs:group>

  <xs:group name="inlineContent">
    <xs:choice>
      <xs:element ref="span"/>
      <xs:element ref="strong"/>
      <xs:element ref="em"/>
      <xs:element ref="br"/>
      <xs:element ref="sc-display"/>
      <xs:element ref="sc-if"/>
    </xs:choice>
  </xs:group>

  <!-- ==================== Root element ==================== -->

  <xs:element name="title" type="xs:string"/>
  <xs:element name="head">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="title"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="body" type="bodyType"/>

  <xs:element name="html">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="head"/>
        <xs:element ref="body"/>
      </xs:sequence>
      <xs:attribute name="id" type="xs:string" use="optional"/>
    </xs:complexType>
  </xs:element>

  <!-- ==================== Complex types ==================== -->

  <xs:complexType name="bodyType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="blockContent"/>
    </xs:choice>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <xs:complexType name="blockType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="blockContent"/>
    </xs:choice>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <xs:complexType name="inlineType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="inlineContent"/>
    </xs:choice>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <xs:complexType name="listType">
    <xs:sequence>
      <xs:element ref="li" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-display -->
  <xs:complexType name="scDisplayType">
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="format" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-if -->
  <xs:complexType name="scIfType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="blockContent"/>
    </xs:choice>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="is-truthy" type="xs:string"/>
    <xs:attribute name="is-falsy" type="xs:string"/>
    <xs:attribute name="is-equal" type="xs:string"/>
    <xs:attribute name="is-not-equal" type="xs:string"/>
    <xs:attribute name="is-greater-than" type="xs:string"/>
    <xs:attribute name="is-lesser-than" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-range -->
  <xs:complexType name="scRangeType">
    <xs:attribute name="type" type="xs:string"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="min" type="xs:decimal"/>
    <xs:attribute name="max" type="xs:decimal"/>
    <xs:attribute name="step" type="xs:decimal"/>
    <xs:attribute name="diameter" type="xs:decimal"/>
    <xs:attribute name="width" type="xs:decimal"/>
    <xs:attribute name="height" type="xs:decimal"/>
    <xs:attribute name="src" type="xs:string"/>
    <xs:attribute name="sprites" type="xs:integer"/>
    <xs:attribute name="fgcolor" type="xs:string"/>
    <xs:attribute name="bgcolor" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-checkbox -->
  <xs:complexType name="scCheckboxType">
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="width" type="xs:decimal"/>
    <xs:attribute name="height" type="xs:decimal"/>
    <xs:attribute name="src" type="xs:string"/>
    <xs:attribute name="fgcolor" type="xs:string"/>
    <xs:attribute name="bgcolor" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-run -->
  <xs:complexType name="scRunType">
    <xs:attribute name="run" type="xs:boolean"/>
    <xs:attribute name="size" type="xs:decimal"/>
    <xs:attribute name="src" type="xs:string"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="fgcolor" type="xs:string"/>
    <xs:attribute name="bgcolor" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-option (an option entry inside sc-select) -->
  <xs:complexType name="scOptionType">
    <xs:attribute name="value" type="xs:decimal" use="required"/>
    <xs:attribute name="label" type="xs:string" use="required"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-select (dropdown input bound to a control or var) -->
  <xs:complexType name="scSelectType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-option"/>
    </xs:choice>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-radio (a radio option inside sc-radio-group) -->
  <xs:complexType name="scRadioType">
    <xs:attribute name="value" type="xs:decimal" use="required"/>
    <xs:attribute name="label" type="xs:string" use="required"/>
    <xs:attribute name="width" type="xs:decimal"/>
    <xs:attribute name="height" type="xs:decimal"/>
    <xs:attribute name="src" type="xs:string"/>
    <xs:attribute name="fgcolor" type="xs:string"/>
    <xs:attribute name="bgcolor" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-radio-group (radio input group bound to a control or var) -->
  <xs:complexType name="scRadioGroupType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-radio"/>
    </xs:choice>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="orientation" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-buffer (declares a server-side buffer) -->
  <xs:complexType name="scBufferType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="frames" type="xs:integer"/>
    <xs:attribute name="channels" type="xs:integer"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-record (waveform viewer + WAV downloader bound to a buffer) -->
  <xs:complexType name="scRecordType">
    <xs:attribute name="bind" type="xs:string" use="required"/>
    <xs:attribute name="width" type="xs:decimal"/>
    <xs:attribute name="height" type="xs:decimal"/>
    <xs:attribute name="window" type="xs:decimal"/>
    <xs:attribute name="size" type="xs:decimal"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-var (declares a named state variable) -->
  <xs:complexType name="scVarType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="value" type="xs:decimal"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-control (declares a named control parameter; value or bind, mutually exclusive) -->
  <xs:complexType name="scControlType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="value" type="xs:decimal"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-group (container: accepts HTML, sc-control, sc-synth, and sc-group children) -->
  <xs:complexType name="scGroupType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="blockContent"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="run" type="xs:boolean"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-synth (accepts sc-control children for parameter declarations) -->
  <xs:complexType name="scSynthType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="run" type="xs:boolean"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-synthdef (container for sc-control and sc-ugen elements, defines a synth graph) -->
  <xs:complexType name="scSynthDefType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
      <xs:element ref="sc-ugen"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-ugen (a single UGen node within a sc-synthdef, accepts sc-control children for inputs) -->
  <xs:complexType name="scUGenType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="type" type="xs:string" use="required"/>
    <xs:attribute name="rate" type="xs:string"/>
    <xs:attribute name="op" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

</xs:schema>
