{
  "name": "@sc-app/synthdef-compiler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SuperCollider SynthDef (SCgf v2) compiler in pure TypeScript. TS port of crates/scsynthdef-compiler.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./builders": "./src/builders/index.ts",
    "./registry": "./src/registry.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate:specs": "node scripts/generate_specs.mjs",
    "generate:builders": "node scripts/generate_builders.mjs",
    "generate": "npm run generate:specs && npm run generate:builders",
    "test": "vitest run",
    "test:watch": "vitest",
    "parity": "tsx examples/node/sclang_parity.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "~5.6.2",
    "vitest": "^2.1.9"
  }
}
